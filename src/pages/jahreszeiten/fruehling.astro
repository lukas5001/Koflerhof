---
import Layout from '../../layouts/Layout.astro';
import Gallery from '../../components/Gallery.astro';

const gallery = [
  { src: '/images/hof/Blumen 1.jpg', alt: 'Frühlingsblumen' },
  { src: '/images/hof/Blumen 2.jpg', alt: 'Blüten' },
  { src: '/images/hof/Blumen 3.jpg', alt: 'Frühlingswiese' },
  { src: '/images/hof/Blumen 4.jpg', alt: 'Blumen 4' },
  { src: '/images/hof/Garten Pfirsiche.JPG', alt: 'Pfirsiche im Garten' },
  { src: '/images/hof/Kastelruth Kirche.jpg', alt: 'Kastelruth im Frühling' },
];
---

<Layout title="Frühling in Südtirol" description="Frühling in Südtirol – blühende Täler, erste Wanderungen und frühlingshafte Stadtbesichtigungen rund um den Koflerhof.">

  <div class="relative pt-32 pb-24 md:pt-52 md:pb-32 overflow-hidden bg-stone-900">
    <img src="/images/hof/Blumen 1.jpg" alt="Frühling in Südtirol" class="absolute inset-0 w-full h-full object-cover opacity-50" />
    <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-black/20"></div>
    <div class="relative container mx-auto px-6 md:px-12 text-center text-white">
      <p class="section-subtitle">März – Mai</p>
      <h1 class="font-serif text-5xl md:text-6xl text-white mb-4">Frühlingserwachen</h1>
      <div class="deco-line"></div>
    </div>
  </div>

  <nav class="bg-cream border-b border-stone-200">
    <div class="container mx-auto px-6 md:px-12 py-3 flex items-center gap-2 text-xs tracking-wider text-stone-500">
      <a href="/" class="hover:text-gold transition-colors">Startseite</a><span>/</span>
      <a href="/jahreszeiten" class="hover:text-gold transition-colors">Südtirol erleben</a><span>/</span>
      <span class="text-stone-700">Frühling</span>
    </div>
  </nav>

  <section class="py-24 md:py-32 bg-linen">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="fade-in">
          <p class="section-subtitle">Natur erwacht</p>
          <h2 class="section-title mb-6">Frühling in Südtirols Tälern</h2>
          <div class="deco-line mx-0 mb-8"></div>
          <p class="prose-kofler mb-6">
            Im Frühling zeigt sich Südtirol von seiner zartesten Seite: Blühende Obstgärten,
            frisches Grün auf den Bergwiesen und der Duft von Blüten in der Luft begleiten
            Ihre Spaziergänge und Wanderungen. Die Temperaturen sind angenehm, die Wege
            noch nicht überfüllt.
          </p>
          <p class="prose-kofler mb-8">
            Vom Koflerhof aus erkunden Sie die mittelalterlichen Städtchen der Region:
            <strong>Klausen</strong> mit dem majestätischen Kloster Säben (10 Min.),
            <strong>Brixen</strong> als kulturelles und wirtschaftliches Zentrum des Eisacktals,
            die Landeshauptstadt <strong>Bozen</strong> und das elegante <strong>Meran</strong>.
          </p>
          <a href="/anfrage" class="btn-primary">Frühjahrsangebot anfragen</a>
        </div>
        <div class="fade-in">
          <img src="/images/hof/Blumen 2.jpg" alt="Frühlingsblüte" class="w-full aspect-[4/5] object-cover shadow-2xl" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid md:grid-cols-3 gap-8 mb-16">
        {[
          { title: 'Städte & Kultur', icon: '🏛️', text: 'Klausen, Brixen, Bozen und Meran mit ihren historischen Altstädten, Museen, Schlössern und Kathedralen erkunden.' },
          { title: 'Wandern & Natur', icon: '🥾', text: 'Erste Frühlingstouren auf mittleren Wegen, blühende Wiesen entlang der Wanderpfade, perfekte Temperaturen ohne Sommerhitze.' },
          { title: 'Sport & Aktivität', icon: '🚴', text: 'Radfahren, Joggen, Klettern, Hallenbad und viele weitere Sportangebote in der Umgebung. Bäuerin Verena hilft gerne bei der Planung.' },
        ].map(item => (
          <div class="fade-in bg-cream p-8 text-center">
            <div class="text-5xl mb-4">{item.icon}</div>
            <h3 class="font-serif text-xl text-stone-800 mb-3">{item.title}</h3>
            <p class="text-stone-600 text-sm leading-relaxed">{item.text}</p>
          </div>
        ))}
      </div>

      <div class="fade-in">
        <Gallery images={gallery} columns={3} />
      </div>
    </div>
  </section>

  <section class="py-20 bg-forest-700 text-white">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="font-serif text-3xl text-white mb-4">Frühlings-Angebot buchen</h2>
          <p class="text-white/80 mb-6">Erleben Sie das Frühlingserwachen auf dem Koflerhof. Das Angebot <em>Frühlingserwachen</em> (14.–28. März 2026) und <em>Blütezeit</em> (11. April – 9. Mai 2026) sind ideal für einen erholsamen Frühlingurlaub.</p>
          <a href="/angebote" class="btn-gold">Angebote ansehen</a>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {[
            { label: 'Frühlingserwachen', price: 'ab 495 €', dates: '14. – 28. März 2026' },
            { label: 'Blütezeit', price: 'ab 505 €', dates: '11. April – 9. Mai 2026' },
          ].map(offer => (
            <div class="bg-white/10 p-6 border border-white/20">
              <p class="font-serif text-2xl text-gold mb-1">{offer.price}</p>
              <p class="font-medium text-white mb-1">{offer.label}</p>
              <p class="text-xs text-white/60 tracking-wider">{offer.dates}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <div class="bg-stone-800 py-6">
    <div class="container mx-auto px-6 md:px-12 flex justify-between items-center">
      <span class="text-stone-500 text-sm">Jahreszeiten</span>
      <div class="flex gap-4">
        <a href="/jahreszeiten" class="text-gold text-sm hover:text-yellow-400 transition-colors">Übersicht</a>
        <a href="/jahreszeiten/sommer" class="text-white/60 text-sm hover:text-gold transition-colors">Sommer →</a>
      </div>
    </div>
  </div>

</Layout>
