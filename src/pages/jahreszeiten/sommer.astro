---
import Layout from '../../layouts/Layout.astro';
import Gallery from '../../components/Gallery.astro';

const gallery = [
  { src: '/images/hof/Seiser Alm.jpg', alt: 'Seiser Alm' },
  { src: '/images/hof/Südtirol Sommer Rittner Horn.jpeg', alt: 'Rittner Horn' },
  { src: '/images/hof/Südtirol Sommer Sass Pordoi.jpeg', alt: 'Sass Pordoi' },
  { src: '/images/hof/Garten Pool 1.jpg', alt: 'Pool' },
  { src: '/images/hof/Garten Liegewiese.jpeg', alt: 'Liegewiese' },
  { src: '/images/hof/Südtirol Weinberg.jpeg', alt: 'Südtiroler Weinberge' },
];
---

<Layout title="Sommer in Südtirol" description="Sommer in Südtirol – wandern auf der Seiser Alm, Baden, Radfahren und herrliche Bergpanoramen direkt vom Koflerhof aus.">

  <div class="relative pt-32 pb-24 md:pt-52 md:pb-32 overflow-hidden bg-stone-900">
    <img src="/images/hof/Seiser Alm.jpg" alt="Seiser Alm im Sommer" class="absolute inset-0 w-full h-full object-cover opacity-50" />
    <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-black/20"></div>
    <div class="relative container mx-auto px-6 md:px-12 text-center text-white">
      <p class="section-subtitle">Juni – August</p>
      <h1 class="font-serif text-5xl md:text-6xl text-white mb-4">Südtiroler Sommer</h1>
      <div class="deco-line"></div>
    </div>
  </div>

  <nav class="bg-cream border-b border-stone-200">
    <div class="container mx-auto px-6 md:px-12 py-3 flex items-center gap-2 text-xs tracking-wider text-stone-500">
      <a href="/" class="hover:text-gold transition-colors">Startseite</a><span>/</span>
      <a href="/jahreszeiten" class="hover:text-gold transition-colors">Südtirol erleben</a><span>/</span>
      <span class="text-stone-700">Sommer</span>
    </div>
  </nav>

  <section class="py-24 md:py-32 bg-linen">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="fade-in">
          <p class="section-subtitle">Alpen & Natur</p>
          <h2 class="section-title mb-6">Sommer in Südtirols Alpen</h2>
          <div class="deco-line mx-0 mb-8"></div>
          <p class="prose-kofler mb-6">
            Der Sommer ist die Hochsaison für Wanderungen und Aktivitäten in Südtirol.
            Die <strong>Seiser Alm</strong> – das größte Hochalm-Plateau in den Alpen – liegt
            nur 10 Minuten entfernt und bietet ein schier unendliches Netz an Wanderwegen
            für alle Fitnessstufen.
          </p>
          <p class="prose-kofler mb-8">
            Zurück am Koflerhof genießen Sie den Pool, die Liegewiese und den Garten.
            Kinder entdecken Tiere, spielen am Spielplatz oder hüpfen auf dem großen Trampolin.
            Die E-Bikes vor Ort ermöglichen ausgedehnte Radtouren durch die malerischen Täler.
          </p>
          <a href="/anfrage" class="btn-primary">Sommer-Urlaub anfragen</a>
        </div>
        <div class="fade-in">
          <img src="/images/hof/Südtirol Sommer Rittner Horn.jpeg" alt="Rittner Horn Panorama" class="w-full aspect-[4/5] object-cover shadow-2xl" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">
        {[
          { title: 'Seiser Alm', icon: '🏔️', sub: '10 Min.', text: 'Größtes Hochalm-Plateau der Alpen. Traumhafte Wanderwege, atemberaubende Aussichten.' },
          { title: 'Gröden', icon: '⛰️', sub: '20 Min.', text: 'Dolomiten-Panorama, anspruchsvolle Bergtouren und herrliche Hütten.' },
          { title: 'Villanderer Alm', icon: '🌿', sub: '30 Min.', text: 'Ruhige Almlandschaft, ideal für Familientouren und gemütliches Wandern.' },
          { title: 'Villnöss', icon: '🦅', sub: '25 Min.', text: 'Naturpark mit imposanten Geislerspitzen – eines der schönsten Täler Südtirols.' },
        ].map(item => (
          <div class="fade-in bg-cream p-6">
            <div class="text-4xl mb-3">{item.icon}</div>
            <div class="flex items-baseline gap-2 mb-2">
              <h3 class="font-serif text-lg text-stone-800">{item.title}</h3>
              <span class="text-xs text-gold tracking-wider">{item.sub}</span>
            </div>
            <p class="text-stone-600 text-sm leading-relaxed">{item.text}</p>
          </div>
        ))}
      </div>
      <div class="fade-in">
        <Gallery images={gallery} columns={3} />
      </div>
    </div>
  </section>

  <section class="py-20 bg-forest-700 text-white">
    <div class="container mx-auto px-6 md:px-12 text-center">
      <h2 class="font-serif text-3xl text-white mb-4">Sommerwanderungen mit Kindern</h2>
      <p class="text-white/80 max-w-2xl mx-auto mb-6">
        In jeder Wohnung finden Sie Wanderbücher und Ausflugsvorschläge speziell für Familien
        mit Kindern. Bäuerin Verena steht Ihnen außerdem persönlich für Empfehlungen zur Verfügung.
      </p>
      <a href="/anfrage" class="btn-gold">Jetzt anfragen</a>
    </div>
  </section>

  <div class="bg-stone-800 py-6">
    <div class="container mx-auto px-6 md:px-12 flex justify-between items-center">
      <a href="/jahreszeiten/fruehling" class="text-white/60 text-sm hover:text-gold transition-colors">← Frühling</a>
      <a href="/jahreszeiten" class="text-gold text-sm hover:text-yellow-400 transition-colors">Übersicht</a>
      <a href="/jahreszeiten/herbst" class="text-white/60 text-sm hover:text-gold transition-colors">Herbst →</a>
    </div>
  </div>

</Layout>
