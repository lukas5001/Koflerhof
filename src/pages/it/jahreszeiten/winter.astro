---
import Layout from '../../../layouts/Layout.astro';
import Gallery from '../../../components/Gallery.astro';

const gallery = [
  { src: '/images/hof/Winter Skifahren.jpeg', alt: 'Sci in Alto Adige' },
  { src: '/images/hof/Seiser Alm Winter 1.jpeg', alt: "Alpe di Siusi in inverno" },
  { src: '/images/hof/Seiser Alm Winter 2.jpeg', alt: "Alpe di Siusi neve" },
  { src: '/images/hof/Koflerhof Winter.JPG', alt: 'Koflerhof in inverno' },
];
---

<Layout title="Inverno in Alto Adige" description="Inverno in Alto Adige – sci di classe mondiale sull'Alpe di Siusi e in Val Gardena, ciaspolate e mercatini di Natale dal Koflerhof.">

  <div class="relative pt-32 pb-24 md:pt-52 md:pb-32 overflow-hidden bg-stone-900">
    <img src="/images/hof/Winter Skifahren.jpeg" alt="Inverno in Alto Adige" class="absolute inset-0 w-full h-full object-cover opacity-50" />
    <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-black/20"></div>
    <div class="relative container mx-auto px-6 md:px-12 text-center text-white">
      <p class="section-subtitle">Dicembre – Marzo</p>
      <h1 class="font-serif text-5xl md:text-6xl text-white mb-4">Inverno in Alto Adige</h1>
      <div class="deco-line"></div>
    </div>
  </div>

  <nav class="bg-cream border-b border-stone-200">
    <div class="container mx-auto px-6 md:px-12 py-3 flex items-center gap-2 text-xs tracking-wider text-stone-500">
      <a href="/it/" class="hover:text-gold transition-colors">Home</a><span>/</span>
      <a href="/it/jahreszeiten" class="hover:text-gold transition-colors">Scopri l'Alto Adige</a><span>/</span>
      <span class="text-stone-700">Inverno</span>
    </div>
  </nav>

  <section class="py-24 md:py-32 bg-linen">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="fade-in">
          <p class="section-subtitle">Neve & avventura</p>
          <h2 class="section-title mb-6">Sci di classe mondiale alle Dolomiti</h2>
          <div class="deco-line mx-0 mb-8"></div>
          <p class="prose-kofler mb-6">
            Il Koflerhof è la base ideale per le vacanze sciistiche sulle Dolomiti.
            L'<strong>Alpe di Siusi</strong> è raggiungibile in soli 10 minuti, la
            <strong>Val Gardena</strong> con le sue piste da sogno in 20 minuti.
            Entrambe fanno parte del comprensorio Dolomiti Superski.
          </p>
          <p class="prose-kofler mb-8">
            Per chi preferisce la neve senza gli sci: le ciaspolate sui sentieri innevati,
            il pattinaggio su ghiaccio e i mercatini di Natale nelle pittoresche piazze
            altoatesine sono esperienze altrettanto indimenticabili.
          </p>
          <div class="grid sm:grid-cols-2 gap-3 mb-8">
            {[
              "Alpe di Siusi (10 min.)",
              'Val Gardena (20 min.)',
              'Dolomiti Superski pass',
              'Ciaspolate e sci di fondo',
              'Pattinaggio su ghiaccio',
              'Mercatini di Natale',
            ].map(item => (
              <div class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-gold shrink-0"></span>
                <span class="text-sm text-stone-700">{item}</span>
              </div>
            ))}
          </div>
          <a href="/it/anfrage" class="btn-primary">Pianifica la tua vacanza invernale</a>
        </div>
        <div class="fade-in">
          <img src="/images/hof/Seiser Alm Winter 1.jpeg" alt="Alpe di Siusi in inverno" class="w-full aspect-[4/3] object-cover shadow-2xl" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-stone-900 text-white">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid md:grid-cols-3 gap-8 text-center">
        {[
          { label: 'Alpe di Siusi', dist: '10 min.', detail: 'Sci, fondo, ciaspolate' },
          { label: 'Val Gardena', dist: '20 min.', detail: '195 km di piste' },
          { label: 'Plan de Corones', dist: '35 min.', detail: 'Sci da discesa' },
        ].map(item => (
          <div class="fade-in">
            <div class="font-serif text-3xl text-gold mb-1">{item.dist}</div>
            <div class="text-white font-medium mb-1">{item.label}</div>
            <div class="text-white/60 text-sm">{item.detail}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 md:py-32 bg-white">
    <div class="container mx-auto px-6 md:px-12">
      <div class="text-center mb-12 fade-in">
        <p class="section-subtitle">Galleria</p>
        <h2 class="section-title">Inverno in Alto Adige</h2>
        <div class="deco-line"></div>
      </div>
      <div class="fade-in">
        <Gallery images={gallery} columns={2} />
      </div>
    </div>
  </section>

  <section class="py-20 bg-forest-700 text-white">
    <div class="container mx-auto px-6 md:px-12 text-center">
      <h2 class="font-serif text-3xl text-white mb-4">Settimane sci da 460 €</h2>
      <p class="text-white/80 max-w-xl mx-auto mb-8">
        7 notti per 2 persone con Mobilcard e pulizia finale incluse – la base ideale per le vostre vacanze sciistiche.
      </p>
      <a href="/it/anfrage" class="btn-gold">Richiedi ora</a>
    </div>
  </section>

  <div class="bg-stone-800 py-6">
    <div class="container mx-auto px-6 md:px-12 flex justify-between items-center">
      <a href="/it/jahreszeiten/herbst" class="text-white/60 text-sm hover:text-gold transition-colors">← Autunno</a>
      <a href="/it/jahreszeiten" class="text-gold text-sm hover:text-yellow-400 transition-colors">Panoramica</a>
      <a href="/it/jahreszeiten/fruehling" class="text-white/60 text-sm hover:text-gold transition-colors">Primavera →</a>
    </div>
  </div>

</Layout>
