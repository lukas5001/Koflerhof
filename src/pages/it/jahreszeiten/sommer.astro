---
import Layout from '../../../layouts/Layout.astro';
import Gallery from '../../../components/Gallery.astro';

const gallery = [
  { src: '/images/hof/Seiser Alm.jpg', alt: "Alpe di Siusi" },
  { src: '/images/hof/Garten Pool 1.png', alt: 'Piscina nel giardino' },
  { src: '/images/hof/Garten Pool und Trampolin.jpg', alt: 'Piscina e trampolino' },
  { src: '/images/hof/Suedtirol Sommer Rittner Horn.jpeg', alt: 'Alto Adige in estate' },
  { src: '/images/hof/Koflerhof Hofumgebung Sommer.jpeg', alt: 'Koflerhof in estate' },
  { src: '/images/hof/Suedtirol Weinberg.jpeg', alt: 'Vigneti altoatesini' },
];
---

<Layout title="Estate in Alto Adige" description="Estate in Alto Adige – escursioni sull'Alpe di Siusi, piscina, gite in E-Bike e panorami montani dal Koflerhof.">

  <div class="relative pt-32 pb-24 md:pt-52 md:pb-32 overflow-hidden bg-stone-900">
    <img src="/images/hof/Seiser Alm.jpg" alt="Estate in Alto Adige" class="absolute inset-0 w-full h-full object-cover opacity-50" />
    <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-black/20"></div>
    <div class="relative container mx-auto px-6 md:px-12 text-center text-white">
      <p class="section-subtitle">Giugno – Agosto</p>
      <h1 class="font-serif text-5xl md:text-6xl text-white mb-4">Estate in Alto Adige</h1>
      <div class="deco-line"></div>
    </div>
  </div>

  <nav class="bg-cream border-b border-stone-200">
    <div class="container mx-auto px-6 md:px-12 py-3 flex items-center gap-2 text-xs tracking-wider text-stone-500">
      <a href="/it/" class="hover:text-gold transition-colors">Home</a><span>/</span>
      <a href="/it/jahreszeiten" class="hover:text-gold transition-colors">Scopri l'Alto Adige</a><span>/</span>
      <span class="text-stone-700">Estate</span>
    </div>
  </nav>

  <section class="py-24 md:py-32 bg-linen">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="fade-in">
          <p class="section-subtitle">Montagna, natura & relax</p>
          <h2 class="section-title mb-6">L'estate più bella sulle Dolomiti</h2>
          <div class="deco-line mx-0 mb-8"></div>
          <p class="prose-kofler mb-6">
            L'estate in Alto Adige è la stagione per chi ama la montagna. A 10 minuti dal Koflerhof
            si apre l'Alpe di Siusi con i suoi infiniti sentieri escursionistici ad alta quota,
            panorami sulle Dolomiti e la tranquillità incontaminata della natura alpina.
          </p>
          <p class="prose-kofler mb-8">
            Di sera, dopo una giornata di escursioni, potrete rilassarvi nella piscina del Koflerhof,
            godervi il tramonto dal prato o cucinare al barbecue con la famiglia.
          </p>
          <div class="grid sm:grid-cols-2 gap-3 mb-8">
            {[
              "Escursioni sull'Alpe di Siusi",
              'Piscina & prato al Koflerhof',
              'Tour in E-Bike nelle valli',
              'Arrampicata sulle Dolomiti',
              'Laghi balneabili nelle vicinanze',
              'Vita notturna & gastronomia',
            ].map(item => (
              <div class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-gold shrink-0"></span>
                <span class="text-sm text-stone-700">{item}</span>
              </div>
            ))}
          </div>
          <a href="/it/anfrage" class="btn-primary">Pianifica la tua estate</a>
        </div>
        <div class="fade-in">
          <img src="/images/hof/Seiser Alm.jpg" alt="Alpe di Siusi" class="w-full aspect-[4/3] object-cover shadow-2xl" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 md:py-32 bg-white">
    <div class="container mx-auto px-6 md:px-12">
      <div class="text-center mb-12 fade-in">
        <p class="section-subtitle">Galleria</p>
        <h2 class="section-title">Estate in Alto Adige</h2>
        <div class="deco-line"></div>
      </div>
      <div class="fade-in">
        <Gallery images={gallery} columns={3} />
      </div>
    </div>
  </section>

  <section class="py-20 bg-forest-700 text-white">
    <div class="container mx-auto px-6 md:px-12 text-center">
      <h2 class="font-serif text-3xl text-white mb-4">Vacanza estiva al Koflerhof</h2>
      <p class="text-white/80 max-w-xl mx-auto mb-8">
        Prenotate in anticipo – l'estate è la stagione più richiesta. Inviateci una richiesta senza impegno.
      </p>
      <a href="/it/anfrage" class="btn-gold">Richiedi ora</a>
    </div>
  </section>

  <div class="bg-stone-800 py-6">
    <div class="container mx-auto px-6 md:px-12 flex justify-between items-center">
      <a href="/it/jahreszeiten/fruehling" class="text-white/60 text-sm hover:text-gold transition-colors">← Primavera</a>
      <a href="/it/jahreszeiten" class="text-gold text-sm hover:text-yellow-400 transition-colors">Panoramica</a>
      <a href="/it/jahreszeiten/herbst" class="text-white/60 text-sm hover:text-gold transition-colors">Autunno →</a>
    </div>
  </div>

</Layout>
