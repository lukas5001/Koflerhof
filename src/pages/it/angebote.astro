---
import Layout from '../../layouts/Layout.astro';

const offers = [
  {
    id: 'fruehling',
    title: 'Risveglio primaverile',
    tagline: 'La natura si risveglia',
    dates: '14 marzo – 28 marzo 2026',
    price: 'da 495 €',
    image: '/images/hof/Blumen 1.jpg',
    highlights: ['7 notti per 2 persone', 'Aria primaverile fresca', 'Prime escursioni', 'Valli in fiore'],
    desc: "Vivete il risveglio primaverile in Alto Adige – quando la natura si desta dopo l'inverno, i frutteti fioriscono e i primi raggi di sole invitano a passeggiate ed escursioni. Una vacanza per l'anima.",
    season: 'Primavera',
    href: '/it/jahreszeiten/fruehling',
  },
  {
    id: 'bluetezeit',
    title: 'Periodo di fioritura',
    tagline: "L'Alto Adige in tutto il suo splendore",
    dates: '11 aprile – 9 maggio 2026',
    price: 'da 505 €',
    image: '/images/hof/Blumen 3.jpg',
    highlights: ['7 notti per 2 persone', 'Mobilcard inclusa', 'Pulizia finale inclusa', 'Fioritura & escursioni'],
    desc: '7 notti per 2 persone inclusa Mobilcard – viaggiate gratuitamente con tutti i mezzi pubblici dell\'Alto Adige e scoprite città, cultura e natura durante il periodo di fioritura più bello.',
    season: 'Primavera',
    href: '/it/jahreszeiten/fruehling',
  },
  {
    id: 'toergelle',
    title: 'Törggelen',
    tagline: 'Tradizione & piaceri',
    dates: '24 ottobre – 14 novembre 2026',
    price: 'da 495 €',
    image: '/images/hof/Herbst Toerggelen.jpeg',
    highlights: ['7 notti per 2 persone', 'Mobilcard inclusa', 'Passeggiate tra i castagni', 'Cultura vinicola altoatesina'],
    desc: 'Passeggiate sui sentieri dei castagneti dorati, ammirate i vigneti nei colori autunnali e gustate il tradizionale Törggelen con vino rosso, castagne e le golose specialità nei masi locali.',
    season: 'Autunno',
    href: '/it/jahreszeiten/herbst',
  },
  {
    id: 'kultur',
    title: 'Settimana cultura & gastronomia',
    tagline: 'Relax & piaceri del palato',
    dates: '14 novembre – 5 dicembre 2026',
    price: 'da 380 €',
    image: '/images/hof/Weihnachten Adventskranz.jpeg',
    highlights: ['7 notti', 'Stagione più economica', 'Mercatini di Natale', 'Scoperte gastronomiche'],
    desc: "Rilassatevi nella quiete del tardo autunno, esplorate i tesori culturali dell'Alto Adige e vivete i primi momenti dell'Avvento nei meravigliosi mercatini di Natale di Bolzano, Bressanone e Chiusa.",
    season: 'Autunno/Inverno',
    href: '/it/jahreszeiten/herbst',
  },
  {
    id: 'ski',
    title: 'Settimane sci & ciaspolate',
    tagline: 'Neve & avventura',
    dates: '9 gennaio – 30 gennaio 2027',
    price: 'da 460 €',
    image: '/images/hof/Winter Skifahren.jpeg',
    highlights: ['7 notti per 2 persone', 'Mobilcard inclusa', 'Pulizia finale inclusa', "Alpe di Siusi (10 min.)"],
    desc: '7 notti per 2 persone inclusa Mobilcard e pulizia finale. Il Koflerhof è il punto di partenza ideale per sciare sull\'Alpe di Siusi (10 min.), in Val Gardena (20 min.) e per le ciaspolate nel paesaggio innevato.',
    season: 'Inverno',
    href: '/it/jahreszeiten/winter',
  },
  {
    id: 'lastminute',
    title: 'Last minute',
    tagline: 'Spontaneo & conveniente',
    dates: 'Fino a 7 giorni prima dell\'arrivo',
    price: '–30% di sconto',
    image: '/images/hof/Sonnenuntergang.jpg',
    highlights: ['Fino a 7 giorni prima', 'Fino al 30% di sconto', 'Decisione spontanea', 'Tutte le stagioni'],
    desc: 'Avete deciso spontaneamente e il Koflerhof ha ancora disponibilità? Approfittate di uno sconto fino al 30% sul prezzo normale. Basta fare una richiesta e verificare la disponibilità!',
    season: 'Tutto l\'anno',
    href: '/it/anfrage',
  },
];
---

<Layout title="Offerte & Speciali" description="Offerte speciali per la vostra vacanza in Alto Adige al Koflerhof – primavera, estate, autunno, inverno e last minute.">

  <div class="relative pt-32 pb-24 md:pt-52 md:pb-32 overflow-hidden bg-stone-900">
    <img src="/images/hof/Seiser Alm.jpg" alt="Offerte Koflerhof" class="absolute inset-0 w-full h-full object-cover opacity-40" />
    <div class="relative container mx-auto px-6 md:px-12 text-center text-white">
      <p class="section-subtitle">Pacchetti speciali</p>
      <h1 class="font-serif text-5xl md:text-6xl text-white mb-4">Le nostre offerte</h1>
      <div class="deco-line"></div>
      <p class="text-white/80 text-lg mt-6 max-w-2xl mx-auto">
        Scoprite i nostri pacchetti per ogni gusto e ogni stagione
      </p>
    </div>
  </div>

  <section class="py-24 md:py-32 bg-linen">
    <div class="container mx-auto px-6 md:px-12">
      <div class="space-y-12">
        {offers.map((offer, idx) => (
          <div class={`grid lg:grid-cols-2 gap-0 overflow-hidden shadow-xl fade-in ${idx % 2 === 1 ? 'lg:flex-row-reverse' : ''}`}>
            <div class={`relative aspect-video lg:aspect-auto ${idx % 2 === 1 ? 'lg:order-2' : ''}`}>
              <img src={offer.image} alt={offer.title} class="w-full h-full object-cover" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-r from-black/30 to-transparent"></div>
              <div class="absolute top-6 left-6">
                <span class="bg-gold text-stone-900 text-xs tracking-widest uppercase px-3 py-1.5">{offer.season}</span>
              </div>
              <div class="absolute bottom-6 left-6">
                <span class="font-serif text-3xl md:text-4xl text-white">{offer.price}</span>
              </div>
            </div>
            <div class={`bg-white p-8 md:p-12 flex flex-col justify-center ${idx % 2 === 1 ? 'lg:order-1' : ''}`}>
              <p class="section-subtitle text-left">{offer.dates}</p>
              <h2 class="font-serif text-3xl text-stone-800 mb-1">{offer.title}</h2>
              <p class="text-gold italic font-serif text-lg mb-4">{offer.tagline}</p>
              <div class="deco-line mx-0 mb-6"></div>
              <p class="text-stone-600 leading-relaxed mb-6">{offer.desc}</p>
              <ul class="grid grid-cols-2 gap-2 mb-8">
                {offer.highlights.map(h => (
                  <li class="flex items-center gap-2 text-sm text-stone-600">
                    <svg class="w-4 h-4 text-gold shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    {h}
                  </li>
                ))}
              </ul>
              <div class="flex flex-wrap gap-3">
                <a href="/it/anfrage" class="btn-primary">Richiedi ora</a>
                <a href={offer.href} class="btn-outline">Scopri di più</a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-forest-700 text-white">
    <div class="container mx-auto px-6 md:px-12 text-center">
      <h2 class="font-serif text-3xl text-white mb-4">Desiderate un'offerta personalizzata?</h2>
      <p class="text-white/80 max-w-xl mx-auto mb-8">
        Nessuna offerta adatta? Contattateci – troveremo insieme la vacanza ideale al Koflerhof.
      </p>
      <a href="/it/anfrage" class="btn-gold">Invia richiesta personale</a>
    </div>
  </section>

</Layout>
