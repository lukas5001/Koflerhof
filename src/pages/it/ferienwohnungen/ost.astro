---
import ApartmentLayout from '../../../layouts/ApartmentLayout.astro';

const gallery = [
  { src: '/images/ferienwohnungen/Ost Wohn-Essbereich Groß.png', alt: 'Soggiorno-cucina' },
  { src: '/images/ferienwohnungen/Ost Wohnbereich hoehere Pixel.jpg', alt: 'Soggiorno' },
  { src: '/images/ferienwohnungen/Ost Kueche.jpeg', alt: 'Cucina' },
  { src: '/images/ferienwohnungen/Ost Schlafzimmer Eltern 1 Groß.png', alt: 'Camera da letto matrimoniale' },
  { src: '/images/ferienwohnungen/Ost Schlafzimmer Eltern 2.jpeg', alt: 'Camera matrimoniale 2' },
  { src: '/images/ferienwohnungen/Ost Schlafzimmer Kinder Groß.png', alt: 'Camera bambini' },
  { src: '/images/ferienwohnungen/Ost Schlafcouch.png', alt: 'Divano letto' },
  { src: '/images/ferienwohnungen/Ost Badezimmer.jpeg', alt: 'Bagno 1' },
  { src: '/images/ferienwohnungen/Ost Badezimmer 2.jpeg', alt: 'Bagno 2' },
  { src: '/images/ferienwohnungen/Ost Terrasse.jpeg', alt: 'Terrazza privata' },
  { src: '/images/ferienwohnungen/Ost Eingang.jpeg', alt: 'Ingresso' },
