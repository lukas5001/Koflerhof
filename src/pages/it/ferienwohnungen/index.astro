---
import Layout from '../../../layouts/Layout.astro';
import ApartmentCard from '../../../components/ApartmentCard.astro';

const apartments = [
  {
    name: 'Appartamento Est',
    slug: 'ost',
    persons: '4–5',
    floor: 'Piano terra',
    bedrooms: '2',
    highlight: 'Appartamento spazioso con terrazza privata e accesso diretto al giardino. Ideale per famiglie con bambini.',
    image: '/images/ferienwohnungen/Ost Wohnbereich hoehere Pixel.jpg',
    badge: 'Particolarmente adatto ai bambini',
  },
  {
    name: 'Appartamento Ovest',
    slug: 'west',
    persons: '3–4',
    floor: 'Piano terra',
    bedrooms: '2',
    highlight: 'Accogliente appartamento al piano terra con ampia cucina-soggiorno e accesso diretto al giardino.',
    image: '/images/ferienwohnungen/West Wohnraum 2.jpeg',
    badge: 'Particolarmente adatto ai bambini',
  },
  {
    name: 'Appartamento Ovest 2',
    slug: 'west2',
    persons: '4',
    floor: '1° piano',
    bedrooms: '2',
    highlight: 'Appartamento luminoso al primo piano con balcone privato e bella vista panoramica sulla zona circostante.',
    image: '/images/ferienwohnungen/West 2 Wohn-Essbereich.jpeg',
    badge: 'Particolarmente adatto ai bambini',
  },
  {
    name: 'Appartamento Sud-Est',
    slug: 'suedost',
    persons: '6',
    floor: '1° piano',
    bedrooms: '3',
    highlight: "Il nostro appartamento più grande con luminoso soggiorno e giardino d'inverno – ideale per famiglie numerose.",
    image: '/images/ferienwohnungen/Suedost Wintergarten.jpg',
    badge: 'Fino a 6 persone',
  },
  {
    name: 'Appartamento Sud-Ovest',
    slug: 'suedwest',
    persons: '4–5',
    floor: 'Piano terra',
    bedrooms: '2',
    highlight: "Appartamento soleggiato con giardino d'inverno e spazio esterno privato con barbecue.",
    image: '/images/ferienwohnungen/Suedwest Wintergarten 1.jpeg',
    badge: 'Particolarmente adatto ai bambini',
  },
];

const inclusions = [
  'Biancheria da letto e asciugamani',
  'Attrezzatura per bambini (lettino, seggiolone, trybike)',
  'Verdura & erbe aromatiche fresche dal giardino (stagionale)',
  'Marmellata di lamponi (fatta in casa)',
  'Calcio balilla, ping pong & trampolino',
  'Guide escursionistiche & giochi da tavolo',
  "Barbecue (privato o condiviso a seconda dell'appartamento)",
  'Sdraio & prato soleggiato',
  'Piscina (stagionale)',
  'Parcheggio & garage per moto',
  'Servizio panini (su richiesta)',
  'Noleggio E-Bike in loco',
  'Wi-Fi gratuito',
  'TV/Sat in tutte le camere',
  'Aria condizionata & ventilazione controllata',
  'Lavatrice',
];
---

<Layout title="Appartamenti al Koflerhof" description="Cinque appartamenti arredati con cura in agriturismo in Alto Adige – per 3–6 persone, adatti alle famiglie e dotati di tutti i comfort.">

  <div class="relative pt-32 pb-20 md:pt-48 md:pb-28 overflow-hidden bg-stone-900">
    <img
      src="/images/ferienwohnungen/Koflerhof Sommer.JPG"
      alt="Appartamenti Koflerhof"
      class="absolute inset-0 w-full h-full object-cover opacity-40"
    />
    <div class="relative container mx-auto px-6 md:px-12 text-center text-white">
      <p class="section-subtitle">Comfort & accoglienza</p>
      <h1 class="font-serif text-5xl md:text-6xl text-white mb-4">Appartamenti</h1>
      <div class="deco-line"></div>
      <p class="text-white/80 text-lg mt-6 max-w-2xl mx-auto">
        Cinque appartamenti arredati con cura per vacanze indimenticabili in Alto Adige
      </p>
    </div>
  </div>

  <section class="py-24 md:py-32 bg-linen">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {apartments.slice(0, 3).map((apt) => (
          <div class="fade-in">
            <ApartmentCard {...apt} />
          </div>
        ))}
      </div>
      <div class="grid md:grid-cols-2 gap-8 mt-8 lg:w-2/3 lg:mx-auto">
        {apartments.slice(3).map((apt) => (
          <div class="fade-in">
            <ApartmentCard {...apt} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 md:py-32 bg-white">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid lg:grid-cols-2 gap-16 items-start">
        <div class="fade-in">
          <p class="section-subtitle">Incluso in tutti gli appartamenti</p>
          <h2 class="section-title mb-6">Tutto per una vacanza perfetta</h2>
          <div class="deco-line mx-0 mb-8"></div>
          <p class="prose-kofler mb-8">
            Vogliamo che vi sentiate completamente a vostro agio al Koflerhof.
            Per questo ogni appartamento è dotato di una serie di servizi
            pensati per il vostro comfort.
          </p>
          <div class="grid sm:grid-cols-2 gap-3">
            {inclusions.map(item => (
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-gold shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                <span class="text-sm text-stone-700">{item}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="fade-in space-y-6">
          <img src="/images/hof/Garten Pool 2.JPG" alt="Piscina nel giardino" class="w-full aspect-[4/3] object-cover shadow-xl" />
          <img src="/images/hof/Garten Liegestuehle.jpeg" alt="Sdraio" class="w-full aspect-video object-cover shadow-xl" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-forest-700 text-white">
    <div class="container mx-auto px-6 md:px-12 text-center">
      <h2 class="font-serif text-3xl md:text-4xl text-white mb-4">Avete trovato il vostro appartamento?</h2>
      <p class="text-white/80 mb-8 max-w-xl mx-auto">Inviateci una richiesta senza impegno e vi risponderemo al più presto.</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/it/anfrage" class="btn-gold">Richiedi ora</a>
        <a href="/it/preise" class="inline-block border-2 border-white/40 text-white px-8 py-3 text-sm tracking-widest uppercase hover:bg-white/10 transition-colors">Vedi prezzi</a>
      </div>
    </div>
  </section>

</Layout>
