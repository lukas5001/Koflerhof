---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Location & How to find us" description="How to reach Koflerhof in Kastelruth, South Tyrol – directions, GPS information and distances to ski resorts and attractions.">

  <div class="relative pt-32 pb-24 md:pt-52 md:pb-32 overflow-hidden bg-stone-900">
    <img src="/images/hof/Koflerhof Ostansicht Sommer.jpg" alt="Koflerhof" class="absolute inset-0 w-full h-full object-cover opacity-40" />
    <div class="relative container mx-auto px-6 md:px-12 text-center text-white">
      <p class="section-subtitle">In the heart of South Tyrol</p>
      <h1 class="font-serif text-5xl md:text-6xl text-white mb-4">Location & How to find us</h1>
      <div class="deco-line"></div>
    </div>
  </div>

  <section class="py-24 md:py-32 bg-linen">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid lg:grid-cols-2 gap-16">

        <div class="fade-in">
          <div class="bg-stone-200 aspect-[4/3] relative overflow-hidden shadow-xl">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2762.5!2d11.5627!3d46.5707!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47829e2a47f31b01%3A0x4f7a4c7c5f7c0000!2sKoflerhof%2C%20Kastelruth%2C%20Südtirol!5e0!3m2!1sen!2sit!4v1234567890"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              class="absolute inset-0"
              title="Koflerhof on the map"
            ></iframe>
          </div>
          <p class="text-xs text-stone-500 mt-2 tracking-wider">GPS: enter Waidbruck / Ponte Gardena 39040</p>
        </div>

        <div class="fade-in">
          <div class="bg-amber-50 border border-amber-200 p-5 mb-8">
            <div class="flex gap-3">
              <svg class="w-5 h-5 text-amber-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
              </svg>
              <div>
                <p class="font-medium text-amber-800 text-sm">Important GPS note</p>
                <p class="text-amber-700 text-sm mt-1">Enter <strong>"Waidbruck 39040"</strong> or <strong>"Ponte Gardena 39040"</strong> – not "Tisens", as there is a village with the same name near Merano!</p>
              </div>
            </div>
          </div>

          <h2 class="font-serif text-2xl text-stone-800 mb-6">Directions without sat-nav</h2>

          <div class="space-y-4">
            {[
              { step: '1', text: 'Take the motorway exit Klausen/Kastelruth (Chiusa/Castelrotto)' },
              { step: '2', text: 'Follow the main road towards Bolzano (9 km)' },
              { step: '3', text: 'At Waidbruck/Ponte Gardena turn left and cross the bridge' },
              { step: '4', text: 'At the roundabout turn right towards Kastelruth/Schlerngebiet' },
              { step: '5', text: 'After 1.5 km: turn right at the first bus stop (sign "KOFLERHOF App.")' },
              { step: '6', text: 'Koflerhof is the first house – entrance behind the building, please ring the bell' },
            ].map(item => (
              <div class="flex items-start gap-4">
                <div class="w-8 h-8 bg-forest-700 text-white rounded-full flex items-center justify-center shrink-0 font-medium text-sm">{item.step}</div>
                <p class="text-stone-700 pt-1">{item.text}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 md:py-32 bg-white">
    <div class="container mx-auto px-6 md:px-12">
      <div class="text-center mb-16 fade-in">
        <p class="section-subtitle">A central location</p>
        <h2 class="section-title">Distances & surroundings</h2>
        <div class="deco-line"></div>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-4xl mx-auto">
        {[
          { dest: 'Seiser Alm', dist: '10 min.', icon: '🏔️', sub: "Europe's largest high alpine plateau" },
          { dest: 'Kastelruth', dist: '15 min.', icon: '🏘️', sub: 'Picturesque mountain village' },
          { dest: 'Klausen', dist: '10 min.', icon: '🏰', sub: 'Medieval historic centre' },
          { dest: 'Grödnertal', dist: '20 min.', icon: '⛷️', sub: '195 km of pistes' },
          { dest: 'Brixen', dist: '20 min.', icon: '⛪', sub: 'Cultural city in Eisacktal' },
          { dest: 'Bozen', dist: '25 min.', icon: '🏙️', sub: 'Capital of South Tyrol' },
          { dest: 'Meran', dist: '45 min.', icon: '🌿', sub: 'Spa & culinary town' },
          { dest: 'Sterzing', dist: '40 min.', icon: '🏔️', sub: 'Gateway to the Brenner' },
          { dest: 'Villnösstal', dist: '25 min.', icon: '🦅', sub: 'Nature park with the Geisler peaks' },
        ].map(item => (
          <div class="fade-in flex items-center gap-4 bg-cream p-5">
            <div class="text-3xl">{item.icon}</div>
            <div class="flex-1">
              <div class="flex items-baseline justify-between">
                <span class="font-medium text-stone-800">{item.dest}</span>
                <span class="text-gold font-serif text-lg">{item.dist}</span>
              </div>
              <p class="text-xs text-stone-500 mt-0.5">{item.sub}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-forest-700 text-white">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="font-serif text-3xl text-white mb-4">By public transport</h2>
          <p class="text-white/80 mb-6 leading-relaxed">
            Many of our offers include the <strong class="text-gold">South Tyrol Mobilcard</strong>.
            With this card you can travel free of charge throughout South Tyrol by bus and train.
          </p>
          <p class="text-white/80 mb-6 leading-relaxed">
            The nearest bus stop is only 300 m from Koflerhof and offers
            regular connections to Kastelruth, Waidbruck/Klausen (station) and the surrounding area.
          </p>
        </div>
        <div class="bg-white/10 p-8 border border-white/20">
          <h3 class="font-serif text-xl text-gold mb-4">By train</h3>
          <ul class="space-y-3 text-white/80 text-sm">
            <li class="flex gap-2">
              <span class="text-gold">→</span>
              <span>Arrive at Waidbruck/Klausen (train)</span>
            </li>
            <li class="flex gap-2">
              <span class="text-gold">→</span>
              <span>Continue by bus towards Kastelruth</span>
            </li>
            <li class="flex gap-2">
              <span class="text-gold">→</span>
              <span>Pick-up possible – please ask when booking</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

</Layout>
