---
import Layout from '../../../layouts/Layout.astro';
import Gallery from '../../../components/Gallery.astro';

const gallery = [
  { src: '/images/hof/Herbst Toerggelen.jpeg', alt: 'Törggelen in autumn' },
  { src: '/images/hof/Herbst Toerggelen 1.jpeg', alt: 'Törggelen tradition' },
  { src: '/images/hof/Suedtirol Weinberg.jpeg', alt: 'South Tyrolean vineyards' },
  { src: '/images/hof/Weihnachten Adventskranz.jpeg', alt: 'Advent' },
];
---

<Layout title="Autumn in South Tyrol" description="Autumn in South Tyrol – Törggelen, golden vineyards, chestnut forests and Christmas markets in the heart of the Dolomites.">

  <div class="relative pt-32 pb-24 md:pt-52 md:pb-32 overflow-hidden bg-stone-900">
    <img src="/images/hof/Herbst Toerggelen.jpeg" alt="Autumn in South Tyrol" class="absolute inset-0 w-full h-full object-cover opacity-50" />
    <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-black/20"></div>
    <div class="relative container mx-auto px-6 md:px-12 text-center text-white">
      <p class="section-subtitle">September – November</p>
      <h1 class="font-serif text-5xl md:text-6xl text-white mb-4">Autumn in South Tyrol</h1>
      <div class="deco-line"></div>
    </div>
  </div>

  <nav class="bg-cream border-b border-stone-200">
    <div class="container mx-auto px-6 md:px-12 py-3 flex items-center gap-2 text-xs tracking-wider text-stone-500">
      <a href="/en/" class="hover:text-gold transition-colors">Home</a><span>/</span>
      <a href="/en/jahreszeiten" class="hover:text-gold transition-colors">Discover South Tyrol</a><span>/</span>
      <span class="text-stone-700">Autumn</span>
    </div>
  </nav>

  <section class="py-24 md:py-32 bg-linen">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="fade-in">
          <p class="section-subtitle">Tradition & colours</p>
          <h2 class="section-title mb-6">South Tyrolean autumn in its most beautiful colours</h2>
          <div class="deco-line mx-0 mb-8"></div>
          <p class="prose-kofler mb-6">
            Autumn in South Tyrol is a unique sensory experience. The vineyards turn golden,
            the chestnut forests fill the crisp air with their scent and the tradition of <strong>Törggelen</strong>
            invites you to savour new wine, roasted chestnuts and the hearty specialities of local farms.
          </p>
          <p class="prose-kofler mb-8">
            As Advent approaches, the picturesque Christmas markets in Bozen, Brixen
            and Klausen come to life – a magical atmosphere that is worth the journey on its own.
          </p>
          <div class="grid sm:grid-cols-2 gap-3 mb-8">
            {[
              'Törggelen tradition',
              'Golden chestnut forest trails',
              'Wine tastings at local wineries',
              'Peaceful autumn hikes',
              'Christmas markets (November)',
              'Affordable shoulder-season prices',
            ].map(item => (
              <div class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-gold shrink-0"></span>
                <span class="text-sm text-stone-700">{item}</span>
              </div>
            ))}
          </div>
          <a href="/en/anfrage" class="btn-primary">Plan your autumn holiday</a>
        </div>
        <div class="fade-in">
          <img src="/images/hof/Suedtirol Weinberg.jpeg" alt="Vineyards in autumn" class="w-full aspect-[4/3] object-cover shadow-2xl" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 md:py-32 bg-white">
    <div class="container mx-auto px-6 md:px-12">
      <div class="text-center mb-12 fade-in">
        <p class="section-subtitle">Gallery</p>
        <h2 class="section-title">Autumn in South Tyrol</h2>
        <div class="deco-line"></div>
      </div>
      <div class="fade-in">
        <Gallery images={gallery} columns={2} />
      </div>
    </div>
  </section>

  <section class="py-20 bg-forest-700 text-white">
    <div class="container mx-auto px-6 md:px-12 text-center">
      <h2 class="font-serif text-3xl text-white mb-4">Törggelen offer from €495</h2>
      <p class="text-white/80 max-w-xl mx-auto mb-8">
        7 nights for 2 persons including Mobilcard – experience the Törggelen tradition in South Tyrol.
      </p>
      <a href="/en/anfrage" class="btn-gold">Inquire now</a>
    </div>
  </section>

  <div class="bg-stone-800 py-6">
    <div class="container mx-auto px-6 md:px-12 flex justify-between items-center">
      <a href="/en/jahreszeiten/sommer" class="text-white/60 text-sm hover:text-gold transition-colors">← Summer</a>
      <a href="/en/jahreszeiten" class="text-gold text-sm hover:text-yellow-400 transition-colors">Overview</a>
      <a href="/en/jahreszeiten/winter" class="text-white/60 text-sm hover:text-gold transition-colors">Winter →</a>
    </div>
  </div>

</Layout>
