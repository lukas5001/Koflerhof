---
import Layout from '../../layouts/Layout.astro';
import ApartmentCard from '../../components/ApartmentCard.astro';
import ReviewCard from '../../components/ReviewCard.astro';

const apartments = [
  {
    name: 'Apartment East',
    slug: 'ost',
    persons: '4–5',
    floor: 'Ground floor',
    bedrooms: '2',
    highlight: 'Spacious apartment with private terrace and direct garden access. Perfect for families with children.',
    image: '/images/ferienwohnungen/Ost Wohnbereich hoehere Pixel.jpg',
    badge: 'Especially child-friendly',
  },
  {
    name: 'Apartment West',
    slug: 'west',
    persons: '3–4',
    floor: 'Ground floor',
    bedrooms: '2',
    highlight: 'Cosy ground-floor apartment with large open-plan kitchen-living area and direct garden access.',
    image: '/images/ferienwohnungen/West Wohnraum 2.jpeg',
    badge: 'Especially child-friendly',
  },
  {
    name: 'Apartment West 2',
    slug: 'west2',
    persons: '4',
    floor: '1st floor',
    bedrooms: '2',
    highlight: 'Bright first-floor apartment with private balcony and lovely views of the surrounding countryside.',
    image: '/images/ferienwohnungen/West 2 Wohn-Essbereich.jpeg',
    badge: 'Especially child-friendly',
  },
  {
    name: 'Apartment South-East',
    slug: 'suedost',
    persons: '6',
    floor: '1st floor',
    bedrooms: '3',
    highlight: 'Our largest apartment with bright living area and winter garden – ideal for larger families.',
    image: '/images/ferienwohnungen/Suedost Wintergarten.jpg',
    badge: 'Up to 6 persons',
  },
  {
    name: 'Apartment South-West',
    slug: 'suedwest',
    persons: '4–5',
    floor: 'Ground floor',
    bedrooms: '2',
    highlight: 'Sunny apartment with winter garden and private outdoor area with BBQ.',
    image: '/images/ferienwohnungen/Suedwest Wintergarten 1.jpeg',
    badge: 'Especially child-friendly',
  },
];

const reviews = [
  {
    headline: 'We were overwhelmed',
    text: 'The Koflerhof exceeded our expectations by far. The apartment was beautiful, the hosts warm and welcoming, and the whole package was simply perfect. We will definitely come back!',
    author: 'Family from Germany',
    source: 'Google',
    date: 'Summer 2025',
    stars: 5,
  },
  {
    headline: 'Wonderful location and truly great hosts!',
    text: "Dream holiday apartment in a magnificent location. The Griesser family is exceptionally attentive and welcoming. You feel at home immediately. The apartment's furnishings are first class.",
    author: 'Family from Germany',
    source: 'Booking.com',
    date: 'Spring 2024',
    stars: 5,
  },
  {
    headline: 'A place to feel truly at home',
    text: "We felt incredibly comfortable from the first to the last day. The garden with pool and trampoline was paradise for our children. The location for hikes on the Seiser Alm is perfect.",
    author: 'Family from Germany',
    source: 'Google',
    date: 'Summer 2023',
    stars: 5,
  },
];
---

<Layout title="Koflerhof – Farm Holiday Apartments in South Tyrol" description="Welcome to Koflerhof in Kastelruth: five lovingly furnished apartments on an authentic South Tyrolean farm, close to the Seiser Alm.">

  <!-- HERO SLIDER -->
  <div class="hero-slider relative h-screen overflow-hidden">
    <div class="swiper h-full" id="hero-swiper">
      <div class="swiper-wrapper">
        {[
          { img: '/images/hof/Koflerhof Hausansicht Sommer 1.JPG', title: 'Welcome to Koflerhof', sub: 'Your piece of paradise in South Tyrol' },
          { img: '/images/hof/Garten Pool Hund.jpeg', title: 'Holidays in nature', sub: 'Our garden awaits you' },
          { img: '/images/hof/Seiser Alm.jpg', title: 'The Seiser Alm on your doorstep', sub: "Europe's largest high-altitude Alpine plateau" },
          { img: '/images/hof/Suedtirol Sommer Rittner Horn.jpeg', title: 'South Tyrol – boundless nature', sub: 'Experience authenticity' },
          { img: '/images/hof/Koflerhof Winter.JPG', title: 'Winter at Koflerhof', sub: 'Fresh snow, clean air and warmth' },
        ].map(slide => (
          <div class="swiper-slide relative">
            <img src={slide.img} alt={slide.title} class="w-full h-full object-cover" loading="eager" />
            <div class="absolute inset-0" style="background:radial-gradient(ellipse at center,rgba(0,0,0,0.55) 0%,rgba(0,0,0,0.2) 60%,rgba(0,0,0,0.45) 100%)"></div>
            <div class="absolute inset-x-0 top-0 h-48" style="background:linear-gradient(to bottom,rgba(0,0,0,0.5) 0%,rgba(0,0,0,0) 100%)"></div>
            <div class="absolute inset-0 flex flex-col items-center justify-center text-center text-white px-6">
              <p class="text-xs md:text-sm tracking-[0.4em] uppercase text-gold mb-4 font-sans" style="text-shadow:0 1px 8px rgba(0,0,0,0.8),0 0 30px rgba(0,0,0,0.5)">{slide.sub}</p>
              <h1 class="font-serif text-4xl md:text-6xl lg:text-7xl max-w-4xl leading-tight" style="text-shadow:0 2px 4px rgba(0,0,0,0.9),0 4px 20px rgba(0,0,0,0.7),0 8px 40px rgba(0,0,0,0.5)">{slide.title}</h1>
            </div>
          </div>
        ))}
      </div>
      <div class="swiper-pagination absolute bottom-10 z-10"></div>
    </div>
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center text-white/70 animate-bounce">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>
  </div>

  <!-- INTRO -->
  <section class="bg-white">
    <div class="grid lg:grid-cols-2 min-h-[70vh]">
      <div class="relative overflow-hidden min-h-[400px]">
        <img src="/images/hof/Koflerhof Hofumgebung Sommer.jpg" alt="Koflerhof" class="absolute inset-0 w-full h-full object-cover" />
        <div class="absolute bottom-8 left-8 bg-white/90 backdrop-blur-sm px-6 py-4 shadow-lg">
          <p class="text-xs tracking-[0.25em] uppercase text-forest-700 font-sans">For generations</p>
          <p class="font-serif text-lg text-stone-800 mt-0.5">Griesser Family · Kastelruth</p>
        </div>
      </div>
      <div class="flex items-center px-8 md:px-16 py-16 md:py-24 bg-white">
        <div class="max-w-lg fade-in">
          <p class="section-subtitle">Welcome</p>
          <h2 class="section-title mb-8">Farm holidays with the Griesser family</h2>
          <div class="deco-line mx-0 mb-8"></div>
          <p class="prose-kofler mb-5">
            Nestled in the picturesque Eisack Valley, just a few kilometres from Kastelruth,
            the Koflerhof welcomes you with five lovingly furnished holiday apartments,
            authentic farm life and all the warmth of our family.
          </p>
          <p class="prose-kofler mb-8">
            Enjoy the tranquillity of the South Tyrolean countryside, let your children
            discover farm life, and set out each morning to explore the Dolomites,
            the Seiser Alm and the charming medieval villages nearby.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/en/ferienwohnungen" class="btn-primary">Discover our apartments</a>
            <a href="/en/anfrage" class="btn-outline">Send inquiry</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- HIGHLIGHTS STRIP -->
  <section class="bg-forest-700 text-white py-14">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-white/20">
        {[
          { icon: '🏔️', label: 'Seiser Alm', sub: '10 min. away' },
          { icon: '🏠', label: '5 Apartments', sub: 'for 3–6 persons' },
          { icon: '🐐', label: 'Farm life', sub: 'Animals & nature' },
          { icon: '🎿', label: 'Ski resorts', sub: '10–20 min. away' },
        ].map(item => (
          <div class="fade-in text-center py-4 px-6">
            <div class="text-4xl mb-2">{item.icon}</div>
            <div class="font-serif text-lg text-gold leading-tight">{item.label}</div>
            <div class="text-xs text-white/60 tracking-wider mt-1">{item.sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PANORAMA -->
  <div class="relative h-[55vh] overflow-hidden">
    <img src="/images/hof/Seiser Alm.jpg" alt="South Tyrol" class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(0,0,0,0.5) 0%, transparent 60%)"></div>
    <div class="absolute inset-0 flex items-center">
      <div class="container mx-auto px-6 md:px-12">
        <p class="font-serif text-3xl md:text-5xl text-white max-w-lg leading-snug fade-in">
          "Where the mountains<br/>touch the sky"
        </p>
      </div>
    </div>
  </div>

  <!-- APARTMENTS -->
  <section class="py-24 md:py-32 bg-white">
    <div class="container mx-auto px-6 md:px-12">
      <div class="text-center mb-16 fade-in">
        <p class="section-subtitle">Comfortable & cosy</p>
        <h2 class="section-title">Our apartments</h2>
        <div class="deco-line"></div>
        <p class="prose-kofler max-w-2xl mx-auto mt-6">
          Five lovingly furnished apartments – each with its own character,
          all equipped with the comfort you deserve for a relaxing holiday.
        </p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {apartments.slice(0, 3).map((apt) => (
          <div class="fade-in">
            <ApartmentCard {...apt} />
          </div>
        ))}
      </div>
      <div class="grid md:grid-cols-2 gap-8 mt-8 lg:w-2/3 lg:mx-auto">
        {apartments.slice(3).map((apt) => (
          <div class="fade-in">
            <ApartmentCard {...apt} />
          </div>
        ))}
      </div>
      <div class="text-center mt-14 fade-in">
        <a href="/en/ferienwohnungen" class="btn-outline">Compare all apartments</a>
      </div>
    </div>
  </section>

  <!-- FARM LIFE -->
  <section class="bg-cream">
    <div class="grid lg:grid-cols-2 min-h-[70vh]">
      <div class="grid grid-cols-2 min-h-[400px]">
        <img src="/images/hof/Tiere Ziege.jpg" alt="Goats" class="w-full h-full object-cover" />
        <img src="/images/hof/Garten Pool 2.JPG" alt="Pool" class="w-full h-full object-cover" />
        <img src="/images/hof/Garten Trampolin.jpeg" alt="Trampoline" class="w-full h-full object-cover" />
        <img src="/images/hof/Garten Spielplatz.jpg" alt="Playground" class="w-full h-full object-cover" />
      </div>
      <div class="flex items-center px-8 md:px-16 py-16 md:py-24">
        <div class="max-w-lg fade-in">
          <p class="section-subtitle">Authentic farm experience</p>
          <h2 class="section-title mb-8">Farm life at Koflerhof</h2>
          <div class="deco-line mx-0 mb-8"></div>
          <p class="prose-kofler mb-6">
            At Koflerhof you will find authentic farm life: goats, rabbits, cats and
            our farm dog Bidu will welcome you. Children can feed the animals and
            experience nature in a truly unique way.
          </p>
          <p class="prose-kofler mb-8">
            The large garden with pool, trampoline, playground and the BBQ gazebo
            is the perfect place to relax and spend evenings together.
          </p>
          <a href="/en/hofleben" class="btn-primary">Discover farm life</a>
        </div>
      </div>
    </div>
  </section>

  <!-- AMENITIES -->
  <section class="py-24 md:py-32 bg-white">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="fade-in lg:order-2">
          <img src="/images/hof/Garten Pool und Trampolin.jpg" alt="Garden with pool" class="w-full aspect-[4/3] object-cover shadow-2xl" />
        </div>
        <div class="fade-in lg:order-1">
          <p class="section-subtitle">All included</p>
          <h2 class="section-title mb-8">The comfort you deserve</h2>
          <div class="deco-line mx-0 mb-8"></div>
          <p class="prose-kofler mb-8">
            Every apartment comes fully equipped for your holiday.
            Enjoy the seasonal pool, trampoline, table football and much more –
            all set in the green heart of South Tyrol.
          </p>
          <div class="grid sm:grid-cols-2 gap-3">
            {[
              'Pool (seasonal)', 'Free Wi-Fi', 'E-Bike rental', 'TV/Sat',
              'Trampoline & table football', 'Free parking', 'Fresh garden vegetables',
              'Home-made jam', 'BBQ', 'Bed linen included',
              "Children's equipment", 'Motorcycle garage',
            ].map(item => (
              <div class="flex items-center gap-3">
                <span class="w-1.5 h-1.5 rounded-full bg-gold shrink-0"></span>
                <span class="text-sm text-stone-700">{item}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SEASONS -->
  <section class="py-24 md:py-32 bg-stone-900 text-white relative overflow-hidden">
    <img
      src="/images/hof/Seiser Alm Winter 1.jpeg"
      alt="South Tyrol"
      class="absolute inset-0 w-full h-full object-cover opacity-20"
    />
    <div class="relative container mx-auto px-6 md:px-12">
      <div class="text-center mb-16 fade-in">
        <p class="section-subtitle">Year-round</p>
        <h2 class="font-serif text-4xl md:text-5xl text-white mb-4">South Tyrol in every season</h2>
        <div class="deco-line"></div>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { name: 'Spring', href: '/en/jahreszeiten/fruehling', img: '/images/hof/Blumen 1.jpg', text: 'Blossoming meadows, first hikes and pleasant temperatures.' },
          { name: 'Summer', href: '/en/jahreszeiten/sommer', img: '/images/hof/Seiser Alm.jpg', text: 'Hikes on the Seiser Alm, pool and breathtaking mountain panoramas.' },
          { name: 'Autumn', href: '/en/jahreszeiten/herbst', img: '/images/hof/Herbst Toerggelen.jpeg', text: 'Golden vineyards and the traditional Törggelen with wine and chestnuts.' },
          { name: 'Winter', href: '/en/jahreszeiten/winter', img: '/images/hof/Winter Skifahren.jpeg', text: 'World-class skiing on the Seiser Alm (10 min.) and in the Gröden valley (20 min.).' },
        ].map(item => (
          <a href={item.href} class="group block fade-in">
            <div class="relative aspect-[3/4] overflow-hidden mb-4">
              <img src={item.img} alt={item.name} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent"></div>
              <div class="absolute bottom-0 left-0 right-0 p-6">
                <h3 class="font-serif text-2xl text-white mb-2">{item.name}</h3>
                <p class="text-white/70 text-sm leading-relaxed">{item.text}</p>
              </div>
            </div>
            <div class="text-gold text-xs tracking-widest uppercase group-hover:text-yellow-400 transition-colors">
              Learn more →
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="py-24 md:py-32 bg-white">
    <div class="container mx-auto px-6 md:px-12">
      <div class="text-center mb-16 fade-in">
        <p class="section-subtitle">What our guests say</p>
        <h2 class="section-title">Reviews</h2>
        <div class="deco-line"></div>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {reviews.map(review => (
          <div class="fade-in">
            <ReviewCard {...review} />
          </div>
        ))}
      </div>
      <div class="text-center mt-12 fade-in">
        <a href="/en/bewertungen" class="btn-outline">All reviews</a>
      </div>
    </div>
  </section>

  <!-- FAMILY CTA -->
  <section class="bg-forest-700">
    <div class="grid lg:grid-cols-2 min-h-[60vh]">
      <div class="relative min-h-[400px] overflow-hidden">
        <img src="/images/hof/Familie Griesser 2.jpg" alt="Griesser Family" class="absolute inset-0 w-full h-full object-cover object-top" />
        <div class="absolute inset-0 bg-black/20"></div>
      </div>
      <div class="flex items-center px-8 md:px-16 py-16 md:py-24">
        <div class="max-w-lg fade-in">
          <p class="section-subtitle">The Griesser Family</p>
          <h2 class="font-serif text-4xl md:text-5xl text-white mb-6 leading-tight">
            We look forward to<br/>
            <span class="text-gold">welcoming you!</span>
          </h2>
          <div class="w-16 h-0.5 bg-gold/50 mb-8"></div>
          <p class="text-white/80 leading-relaxed mb-10">
            Whether for a summer break or a winter ski trip – at Koflerhof
            you will find a warm and welcoming place to call home. We can't wait to meet you!
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/en/anfrage" class="btn-gold">Send inquiry</a>
            <a href="/en/ferienwohnungen" class="btn-outline border-white/40 text-white hover:bg-white/10">Discover apartments</a>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    if ((window as any).Swiper) {
      new (window as any).Swiper('#hero-swiper', {
        loop: true,
        autoplay: { delay: 5500, disableOnInteraction: false },
        effect: 'fade',
        fadeEffect: { crossFade: true },
        speed: 1200,
        pagination: { el: '.swiper-pagination', clickable: true },
      });
    }
  });
</script>
