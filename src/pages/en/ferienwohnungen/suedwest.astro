    'Private outdoor area with barbecue',
    'TV/Sat in all rooms',
    'Free Wi-Fi',
    'Washing machine',
    'Controlled ventilation',
    'Air conditioning',
    'Bathroom',
  ]}
  inclusions={[
    'Bed linen & towels',
    'Baby & toddler equipment on request',
    'Vegetables & herbs from the garden',
