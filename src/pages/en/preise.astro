---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Prices & Conditions" description="Prices for apartments at Koflerhof in South Tyrol – per day, per season, cancellation conditions and payment methods.">

  <div class="relative pt-32 pb-24 md:pt-52 md:pb-32 overflow-hidden bg-stone-900">
    <img src="/images/hof/Koflerhof Hausansicht Sommer 2.jpg" alt="Koflerhof" class="absolute inset-0 w-full h-full object-cover opacity-40" />
    <div class="relative container mx-auto px-6 md:px-12 text-center text-white">
      <p class="section-subtitle">Transparency & fairness</p>
      <h1 class="font-serif text-5xl md:text-6xl text-white mb-4">Prices</h1>
      <div class="deco-line"></div>
    </div>
  </div>

  <section class="py-24 md:py-32 bg-linen">
    <div class="container mx-auto px-6 md:px-12">
      <div class="max-w-5xl mx-auto">

        <div class="text-center mb-16 fade-in">
          <p class="section-subtitle">Price overview</p>
          <h2 class="section-title">Prices per day</h2>
          <div class="deco-line"></div>
          <p class="text-stone-600 mt-4">Per apartment · Minimum stay 5 nights · Prices for 2 persons</p>
        </div>

        <div class="grid md:grid-cols-3 gap-8 mb-16 fade-in">
          {[
            {
              label: 'Low season',
              range: '65 – 90 €',
              color: 'bg-sage/20 border-sage',
              textColor: 'text-forest-700',
              months: 'Spring & late autumn',
              desc: 'Quiet seasons with pleasant temperatures and fewer visitors.',
            },
            {
              label: 'Mid season',
              range: '90 – 135 €',
              color: 'bg-gold/20 border-gold',
              textColor: 'text-earth-700',
              months: 'Pre and post season',
              desc: 'The perfect balance between activity and tranquillity.',
            },
            {
              label: 'High season',
              range: '135 – 180 €',
              color: 'bg-forest-700/10 border-forest-700',
              textColor: 'text-forest-700',
              months: 'Summer & winter',
              desc: 'Peak season with the full programme – skiing, hiking, swimming.',
            },
          ].map(tier => (
            <div class={`border-2 ${tier.color} p-8 text-center`}>
              <p class="text-xs tracking-widest uppercase text-stone-500 mb-2">{tier.months}</p>
              <h3 class={`font-serif text-2xl ${tier.textColor} mb-2`}>{tier.label}</h3>
              <div class={`font-serif text-4xl ${tier.textColor} my-4`}>{tier.range}</div>
              <p class="text-xs text-stone-400 mb-3">per day / per apartment</p>
              <p class="text-stone-600 text-sm leading-relaxed">{tier.desc}</p>
            </div>
          ))}
        </div>

        <div class="grid md:grid-cols-2 gap-8 mb-16">
          <div class="fade-in bg-white p-8 shadow-sm">
            <h3 class="font-serif text-xl text-stone-800 mb-6">Additional costs</h3>
            <div class="space-y-4">
              {[
                { item: 'Each additional person', price: '€10 / day' },
                { item: 'Pet (dog)', price: '€6 / day' },
                { item: 'Final cleaning', price: '€48' },
                { item: 'Tourist tax (from age 14)', price: '€2.50 / person / day' },
              ].map(cost => (
                <div class="flex items-center justify-between py-2 border-b border-stone-100 last:border-0">
                  <span class="text-stone-700">{cost.item}</span>
                  <span class="font-medium text-forest-700">{cost.price}</span>
                </div>
              ))}
            </div>
          </div>

          <div class="fade-in bg-white p-8 shadow-sm">
            <h3 class="font-serif text-xl text-stone-800 mb-6">Arrival & departure</h3>
            <div class="space-y-4">
              {[
                { label: 'Arrival', val: 'From 14:00' },
                { label: 'Departure', val: 'By 09:30' },
                { label: 'Luggage storage', val: 'Possible on request' },
                { label: 'Minimum stay', val: '5 nights' },
              ].map(item => (
                <div class="flex items-center justify-between py-2 border-b border-stone-100 last:border-0">
                  <span class="text-stone-700">{item.label}</span>
                  <span class="font-medium text-stone-600">{item.val}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="grid md:grid-cols-2 gap-8 fade-in">
          <div class="bg-forest-700 text-white p-8">
            <h3 class="font-serif text-xl text-white mb-6">Payment</h3>
            <ul class="space-y-3 text-white/80 text-sm">
              <li class="flex gap-3">
                <svg class="w-5 h-5 text-gold shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                <span>Deposit of 30–40% of the total amount on confirmation of booking</span>
              </li>
              <li class="flex gap-3">
                <svg class="w-5 h-5 text-gold shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                <span>Balance due on arrival</span>
              </li>
              <li class="flex gap-3">
                <svg class="w-5 h-5 text-gold shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                <span>Booking confirmed only upon receipt of deposit</span>
              </li>
            </ul>
          </div>

          <div class="bg-cream p-8">
            <h3 class="font-serif text-xl text-stone-800 mb-6">Cancellation conditions</h3>
            <div class="space-y-3">
              {[
                { cond: '29–14 days before arrival', pct: '60% of total' },
                { cond: 'Less than 14 days', pct: '80% of total' },
                { cond: 'No notification', pct: '100% of total' },
                { cond: 'Early departure', pct: '100% of total' },
              ].map(s => (
                <div class="py-2 border-b border-stone-200 last:border-0">
                  <div class="text-sm text-stone-500 mb-0.5">{s.cond}</div>
                  <div class="text-sm font-medium text-earth-700">{s.pct}</div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="mt-10 bg-stone-100 p-6 text-sm text-stone-600 leading-relaxed fade-in">
          <strong>Note:</strong> The European Commission provides a platform for online dispute resolution:
          <a href="http://ec.europa.eu/consumers/odr/" target="_blank" rel="noopener" class="text-forest-700 hover:underline ml-1">
            ec.europa.eu/consumers/odr
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="container mx-auto px-6 md:px-12 text-center">
      <h2 class="font-serif text-3xl text-stone-800 mb-4">Ready for your holiday?</h2>
      <p class="text-stone-600 mb-8 max-w-xl mx-auto">Send us a non-binding inquiry – we will confirm availability and price as soon as possible.</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/en/anfrage" class="btn-primary">Inquire without obligation</a>
        <a href="/en/angebote" class="btn-outline">Our special offers</a>
      </div>
    </div>
  </section>

</Layout>
