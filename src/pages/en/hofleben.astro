---
import Layout from '../../layouts/Layout.astro';
import Gallery from '../../components/Gallery.astro';

const gardenGallery = [
  { src: '/images/hof/Garten Pool 1.png', alt: 'Garden pool' },
  { src: '/images/hof/Garten Pool und Spielbereich.jpg', alt: 'Pool and play area' },
  { src: '/images/hof/Garten Pool und Trampolin.jpg', alt: 'Pool and trampoline' },
  { src: '/images/hof/Garten Liegewiese.jpeg', alt: 'Sunbathing lawn' },
  { src: '/images/hof/Garten Liegestuehle.jpeg', alt: 'Sunloungers' },
  { src: '/images/hof/Garten Trampolin.jpeg', alt: 'Trampoline' },
  { src: '/images/hof/Garten Ping Pong.jpeg', alt: 'Ping pong' },
  { src: '/images/hof/Garten Gartenhuette.jpg', alt: 'Garden gazebo' },
  { src: '/images/hof/Gartenhuette Tisch.jpg', alt: 'Gazebo table' },
  { src: '/images/hof/Garten Liegewiese Spielplatz.jpg', alt: 'Play area' },
];

const animalsGallery = [
  { src: '/images/hof/Tiere Ziege.jpg', alt: 'Goat' },
  { src: '/images/hof/Tiere Ziegen fuettern.jpeg', alt: 'Feeding the goats' },
  { src: '/images/hof/Tiere Ziegen Hund.jpg', alt: 'Goats and dog Bidu' },
  { src: '/images/hof/Tiere Hasen.jpg', alt: 'Rabbits' },
  { src: '/images/hof/Tiere Hasen Kopie.jpg', alt: 'Rabbits 2' },
  { src: '/images/hof/Tiere Katzen.jpg', alt: 'Cats' },
  { src: '/images/hof/Tiere Bidu.JPG', alt: 'Farm dog Bidu' },
];

const gardenProduce = [
  { src: '/images/hof/Garten Gemuese.JPG', alt: 'Vegetables from the garden' },
  { src: '/images/hof/Garten Kraeuter.jpeg', alt: 'Fresh herbs' },
  { src: '/images/hof/Garten Pfirsiche.JPG', alt: 'Peaches' },
  { src: '/images/hof/Garten Nuesse.jpg', alt: 'Walnuts' },
  { src: '/images/hof/Himbeeren.jpg', alt: 'Raspberries' },
  { src: '/images/hof/Apfelstrudel.png', alt: 'Home-made apple strudel' },
];
---

<Layout title="Farm Life at Koflerhof" description="Discover authentic farm life at Koflerhof: animals, garden, swimming pool, play area and plenty of nature for the whole family.">

  <div class="relative pt-32 pb-24 md:pt-52 md:pb-32 overflow-hidden bg-stone-900">
    <img src="/images/hof/Koflerhof Sommer.JPG" alt="Koflerhof in summer" class="absolute inset-0 w-full h-full object-cover opacity-40" />
    <div class="relative container mx-auto px-6 md:px-12 text-center text-white">
      <p class="section-subtitle">Authentic country living</p>
      <h1 class="font-serif text-5xl md:text-6xl text-white mb-4">Farm Life</h1>
      <div class="deco-line"></div>
      <p class="text-white/80 text-lg mt-6 max-w-2xl mx-auto">
        Nature, animals, fresh air and plenty of space to play and relax
      </p>
    </div>
  </div>

  <section class="py-24 md:py-32 bg-linen">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid lg:grid-cols-2 gap-16 items-center mb-20">
        <div class="fade-in">
          <p class="section-subtitle">For all guests</p>
          <h2 class="section-title mb-6">Garden & recreation</h2>
          <div class="deco-line mx-0 mb-8"></div>
          <p class="prose-kofler mb-6">
            The generous garden at Koflerhof is available to all our guests.
            Whether you want to relax by the pool, read on the lawn, grill on the barbecue or
            play with the children in the play area – there is something for everyone here.
          </p>
          <p class="prose-kofler mb-8">
            The garden gazebo with barbecue is the perfect spot for convivial evenings.
            Children love the large trampoline, sandbox, swings and slide.
          </p>
          <div class="grid sm:grid-cols-2 gap-4">
            {[
              'Swimming pool (seasonal)',
              'Lawn & sunloungers',
              'Garden gazebo with barbecue',
              'Large trampoline',
              'Play area (swings, slide, sandbox)',
              'Table tennis',
              'Table football',
              'Scooters & children\'s toys',
              'Trybike',
            ].map(item => (
              <div class="flex items-center gap-3">
                <svg class="w-4 h-4 text-gold shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                <span class="text-sm text-stone-700">{item}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="fade-in">
          <img src="/images/hof/Garten Pool Hund.jpeg" alt="Pool with farm dog" class="w-full aspect-[4/5] object-cover shadow-2xl" />
        </div>
      </div>

      <div class="fade-in">
        <Gallery images={gardenGallery} columns={4} />
      </div>
    </div>
  </section>

  <section class="py-24 md:py-32 bg-white">
    <div class="container mx-auto px-6 md:px-12">
      <div class="text-center mb-16 fade-in">
        <p class="section-subtitle">Farm experience</p>
        <h2 class="section-title">Our animals</h2>
        <div class="deco-line"></div>
      </div>

      <div class="grid lg:grid-cols-2 gap-16 items-center mb-16">
        <div class="fade-in">
          <Gallery images={animalsGallery} columns={3} />
        </div>
        <div class="fade-in">
          <p class="prose-kofler mb-6">
            At Koflerhof, farm life is authentic – and that means animals!
            Our guests, especially the younger ones, love feeding the goats, playing
            with the rabbits and stroking our two cats.
          </p>
          <p class="prose-kofler mb-8">
            Our farm dog <strong>Bidu</strong> is also a faithful companion on the farm
            and is delighted by every visit. Guests' dogs are of course very welcome at Koflerhof!
          </p>
          <div class="bg-cream p-6 border-l-4 border-gold">
            <p class="font-serif text-lg text-stone-800 italic">
              "The children didn't want to go home –
              especially because of the goats and dog Bidu!"
            </p>
            <p class="text-sm text-stone-500 mt-2">— Guest family, summer 2024</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 md:py-32 bg-cream">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="fade-in">
          <p class="section-subtitle">Fresh & local</p>
          <h2 class="section-title mb-6">From our garden</h2>
          <div class="deco-line mx-0 mb-8"></div>
          <p class="prose-kofler mb-6">
            In summer you will find fresh vegetables and herbs from our garden waiting in your apartment.
            Tomatoes, courgettes, herbs and, depending on the season, much more besides – all pesticide-free, grown with love.
          </p>
          <p class="prose-kofler mb-6">
            Our home-made <strong>raspberry jam</strong> is a particular favourite with guests
            and is the perfect start to a holiday morning.
          </p>
          <p class="prose-kofler mb-8">
            On request we bring fresh rolls directly to your apartment every morning –
            the perfect start to a full day in South Tyrol.
          </p>
          <a href="/en/anfrage" class="btn-primary">Send inquiry</a>
        </div>
        <div class="fade-in">
          <Gallery images={gardenProduce} columns={3} />
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 md:py-32 bg-forest-700 text-white">
    <div class="container mx-auto px-6 md:px-12">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12 fade-in">
          <p class="text-xs tracking-[0.35em] uppercase text-gold mb-3">Finding your way around</p>
          <h2 class="font-serif text-4xl text-white mb-4">How to find your apartment</h2>
          <div class="deco-line"></div>
        </div>
        <div class="grid md:grid-cols-2 gap-8 fade-in">
          {[
            { apt: 'Apt. East & West', desc: 'Ground floor on the north side of the building. Parking to the left of the driveway.' },
            { apt: 'Apt. West 2', desc: 'Access from the west side of the building, go up to the first floor.' },
            { apt: 'Apt. South-East', desc: 'Access from the east side of the building, go up to the first floor.' },
            { apt: 'Apt. South-West', desc: 'Access from the west side of the building, ground floor.' },
          ].map(item => (
            <div class="bg-white/10 p-6 border border-white/20">
              <h3 class="font-serif text-xl text-gold mb-2">{item.apt}</h3>
              <p class="text-white/80 text-sm leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 md:py-32 bg-linen">
    <div class="container mx-auto px-6 md:px-12">
      <div class="text-center mb-16 fade-in">
        <p class="section-subtitle">Right on the doorstep</p>
        <h2 class="section-title">The surroundings of Koflerhof</h2>
        <div class="deco-line"></div>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { title: 'Hiking trails', image: '/images/hof/Suedtirol Sommer Rittner Horn.jpeg', text: 'Forest trails directly from the farm, tips in the information guide' },
          { title: 'Seiser Alm', image: '/images/hof/Seiser Alm.jpg', text: "Europe's largest high alpine plateau, only 10 minutes away" },
          { title: 'Kastelruth', image: '/images/hof/Kastelruth Kirche.jpg', text: 'Picturesque village with historic centre, 15 minutes away' },
          { title: 'South Tyrol', image: '/images/hof/Suedtirol Weinberg.jpeg', text: 'Vineyards, Dolomites, culture and cuisine all around' },
        ].map(item => (
          <div class="fade-in bg-white shadow-sm overflow-hidden">
            <img src={item.image} alt={item.title} class="w-full aspect-video object-cover" loading="lazy" />
            <div class="p-5">
              <h3 class="font-serif text-lg text-stone-800 mb-2">{item.title}</h3>
              <p class="text-stone-600 text-sm leading-relaxed">{item.text}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="text-center mt-12 fade-in">
        <a href="/en/jahreszeiten" class="btn-primary">Discover South Tyrol</a>
      </div>
    </div>
  </section>

</Layout>
