const gallery = [
  { src: '/images/ferienwohnungen/Ost Wohn-Essbereich Groß.png', alt: 'Wohn-Essbereich' },
  { src: '/images/ferienwohnungen/Ost Wohnbereich hoehere Pixel.jpg', alt: 'Wohnbereich' },
  { src: '/images/ferienwohnungen/Ost Kueche.jpeg', alt: 'Küche' },
  { src: '/images/ferienwohnungen/Ost Schlafzimmer Eltern 1 Groß.png', alt: 'Elternschlafzimmer' },
  { src: '/images/ferienwohnungen/Ost Schlafzimmer Eltern 2.jpeg', alt: 'Elternschlafzimmer 2' },
  { src: '/images/ferienwohnungen/Ost Schlafzimmer Kinder Groß.png', alt: 'Kinderschlafzimmer' },
  { src: '/images/ferienwohnungen/Ost Schlafcouch.png', alt: 'Schlafcouch' },
  { src: '/images/ferienwohnungen/Ost Badezimmer.jpeg', alt: 'Bad 1' },
  { src: '/images/ferienwohnungen/Ost Badezimmer 2.jpeg', alt: 'Bad 2' },
