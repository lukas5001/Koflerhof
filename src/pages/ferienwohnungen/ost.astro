---

<ApartmentLayout
  title="Wohnung Ost"
  subtitle="Ferienwohnung · Erdgeschoss"
  description="Die <strong>Wohnung Ost</strong> befindet sich im Erdgeschoss auf der Nordseite des Koflerhofs und bietet Platz für 4 bis 5 Personen. Die großzügige Wohnküche, zwei separate Schlafzimmer sowie eine private Terrasse mit direktem Gartenzugang machen diese Wohnung zur idealen Wahl für Familien mit Kindern.<br/><br/>Die vollausgestattete Küche lässt keine Wünsche offen. Vom Gemüsemesser bis zur Kaffeemaschine ist alles vorhanden. Ein gemütliches Wohnzimmer mit Schlafcouch bietet zusätzliche Flexibilität. Saisonal profitieren Sie von frischem Gemüse und Kräutern aus unserem Garten."
  headerImage="/images/ferienwohnungen/Ost Wohnbereich hoehere Pixel.jpg"
  persons="4–5"
  floor="Erdgeschoss, Nordseite"
  bedrooms="2"
  extra="Private Terrasse"
  badge="Besonders kinderfreundlich"
  beds={[
    '1× Doppelbett (Elternschlafzimmer)',
    '2× Einzelbett (Kinderschlafzimmer)',
    'Schlafcouch für 2 Personen (Wohnküche)',
  ]}
  features={[
    'Vollausgestattete Küche',
    'Private Terrasse mit Gartenzugang',
    'TV/Sat in allen Zimmern',
    'Kostenloses WLAN',
    'Waschmaschine',
    'Kontrollierte Lüftung',
    'Klimaanlage',
    '2 Vollbäder',
  ]}
  inclusions={[
    'Bettwäsche & Handtücher',
    'Kinderausstattung (Kinderbett, Hochstuhl)',
    'Trybike & Kinderfahrzeuge',
    'Gemüse & Kräuter aus dem Garten',
    'Himbeermarmelade (hausgemacht)',
    'Brötchenservice (auf Wunsch)',
    'Endreinigung separat buchbar',
  ]}
  gallery={gallery}
  floorPlan="/images/ferienwohnungen/Ost Wohnungsskizze.png"
  prevApt={{ name: 'Wohnung Suedwest', href: '/ferienwohnungen/suedwest' }}
  nextApt={{ name: 'Wohnung West', href: '/ferienwohnungen/west' }}
/>
