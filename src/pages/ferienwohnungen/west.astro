  { src: '/images/ferienwohnungen/West Wohnraum 3.jpg', alt: 'Wohnraum 2' },
  { src: '/images/ferienwohnungen/West Küche 1.jpg', alt: 'Küche' },
  { src: '/images/ferienwohnungen/West Küche 2.jpg', alt: 'Küche 2' },
  { src: '/images/ferienwohnungen/West Schlafzimmer 1.jpeg', alt: 'Schlafzimmer 1' },
  { src: '/images/ferienwohnungen/West Schlafzimmer 2.jpeg', alt: 'Schlafzimmer 2' },
