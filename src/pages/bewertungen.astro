---
import Layout from '../layouts/Layout.astro';
import ReviewCard from '../components/ReviewCard.astro';

const reviews = [
  {
    headline: 'Wir waren überwältigt',
    text: 'Der Koflerhof hat unsere Erwartungen bei weitem übertroffen. Die Wohnung war wunderschön, die Gastgeber herzlich und das Gesamtpaket einfach perfekt. Wir kommen definitiv wieder! Die Kinder hatten die schönsten zwei Wochen ihrer bisherigen Urlaubsgeschichte.',
    author: 'Familie aus Deutschland',
    source: 'Google',
    date: 'Sommer 2025',
    stars: 5,
  },
  {
    headline: 'Wunderschöne Lage und wirklich tolle Gastgeber!',
    text: 'Traumhafte Ferienwohnung in herrlicher Lage. Die Familie Griesser ist außerordentlich aufmerksam und herzlich. Man fühlt sich sofort willkommen. Die Ausstattung der Wohnung ist erstklassig, die Sauberkeit tadellos.',
    author: 'Familie aus Deutschland',
    source: 'Booking.com',
    date: 'Frühjahr 2024',
    stars: 5,
  },
  {
    headline: 'Ein Ort zum Wohlfühlen',
    text: 'Wir haben uns vom ersten bis zum letzten Tag unglaublich wohl gefühlt. Der Garten mit Pool und Trampolin war für unsere Kinder das Paradies. Die Lage für Ausflüge auf die Seiser Alm ist perfekt.',
    author: 'Familie aus Deutschland',
    source: 'Google',
    date: 'Sommer 2023',
    stars: 5,
  },
  {
    headline: 'Außergewöhnlich',
    text: 'Eine außergewöhnliche Unterkunft in einer traumhaften Umgebung. Die Gastgeber gehen weit über das normale Maß an Gastfreundschaft hinaus. Wir kommen nächstes Jahr wieder!',
    author: 'Familie aus Deutschland',
    source: 'Booking.com',
    date: 'Frühjahr 2022',
    stars: 5,
  },
  {
    headline: 'Gastfreundschaft, Aufmerksamkeit und Herzlichkeit',
    text: 'Was uns am meisten beeindruckt hat, war die Herzlichkeit der Gastgeberfamilie. Frisches Gemüse aus dem Garten, die selbstgemachte Marmelade zum Frühstück – kleine Gesten, die viel bedeuten.',
    author: 'Familie aus Deutschland',
    source: 'Google',
    date: 'Sommer 2022',
    stars: 5,
  },
  {
    headline: 'Ich würde 6 Sterne geben, wenn ich könnte',
    text: 'Absolut fantastischer Urlaub! Vom ersten Moment an haben wir uns wie zu Hause gefühlt. Die Tiere, der Garten, der Pool – einfach wunderbar. Die Umgebung bietet für jeden etwas: Wanderungen, Ski, Kultur.',
    author: 'Familie aus Deutschland',
    source: 'Google',
    date: 'Sommer 2022',
    stars: 5,
  },
  {
    headline: 'Wir haben uns sehr wohl gefühlt',
    text: 'Schöne, saubere und gut ausgestattete Wohnung mit netten Gastgebern. Der Garten und die Lage sind top. Für Familien mit Kindern sehr zu empfehlen!',
    author: 'Familie aus Deutschland',
    source: 'FeWo-direkt',
    date: 'Sommer 2022',
    stars: 5,
  },
  {
    headline: 'Große, saubere Apartments und viele Annehmlichkeiten',
    text: 'Molto belle le stanze, pulite e con tutti i comfort. I proprietari sono molto gentili e disponibili. Il giardino con la piscina è fantastico per le famiglie.',
    author: 'Gäste aus Italien',
    source: 'Google',
    date: 'Winter 2022',
    stars: 5,
  },
  {
    headline: 'Strategisch gut gelegener Ort',
    text: 'Posizione strategica per visitare tutta la zona. Casa pulita e accogliente. Host disponibili e gentili. Torneremo sicuramente!',
    author: 'Familie aus Italien',
    source: 'Google',
    date: 'Sommer 2021',
    stars: 5,
  },
  {
    headline: 'Wir haben die Ruhe auf dem Hof genossen',
    text: 'Traumhafter Urlaub! Die Ruhe auf dem Hof, die frische Luft, die Gastfreundschaft der Familie – alles hat gestimmt. Die Wandertipps von Verena waren Gold wert.',
    author: 'Familie aus Deutschland',
    source: 'Google',
    date: 'Sommer 2021',
    stars: 5,
  },
  {
    headline: 'Perfekte Ferienwohnung in unmittelbarer Nähe von Kastelruth',
    text: 'Top Lage, perfekte Ausstattung, herzliche Gastgeber. Wir haben uns sofort wohl gefühlt. Für den Skiurlaub in Gröden und auf der Seiser Alm ideal gelegen.',
    author: 'Familie aus Deutschland',
    source: 'Booking.com',
    date: 'Winter 2021',
    stars: 5,
  },
  {
    headline: 'Meraviglioso',
    text: 'Posto meraviglioso, ospiti fantastici. Le strutture sono ottime, la pulizia impeccabile. Consiglio vivamente questo posto a tutti.',
    author: 'Familie aus Italien',
    source: 'Booking.com',
    date: 'Sommer 2021',
    stars: 5,
  },
  {
    headline: 'Familienurlaub mit Hund',
    text: 'Wir waren mit unserem Hund dort und wurden herzlich willkommen geheißen. Der Garten ist toll, der Hund hatte Spaß mit Bidu. Sehr empfehlenswert für Hundebesitzer!',
    author: 'Familie aus Deutschland',
    source: 'Google',
    date: '2020',
    stars: 5,
  },
  {
    headline: 'Gemütlich und familienfreundlich',
    text: 'Eine sehr schöne, gemütliche Ferienwohnung in herrlicher Lage. Für Familien mit Kindern absolut zu empfehlen – die Kinder hatten Spaß mit den Tieren und im Garten.',
    author: 'Familie aus Deutschland',
    source: 'FeWo-direkt',
    date: 'Sommer 2019',
    stars: 5,
  },
  {
    headline: 'Sehr sauber',
    text: 'Wir waren im Frühjahr dort und haben uns sehr wohl gefühlt. Die Wohnung ist gepflegt und sauber, die Gastgeber aufmerksam und freundlich.',
    author: 'Gäste aus Deutschland',
    source: 'FeWo-direkt',
    date: 'Frühjahr 2016',
    stars: 4,
  },
  {
    headline: 'Skiurlaub – beste Lage!',
    text: 'Für den Skiurlaub auf der Seiser Alm und in Gröden ist der Koflerhof ideal gelegen. Gemütliche Wohnungen, freundliche Gastgeber und kurze Wege zu den Pisten.',
    author: 'Gäste aus Deutschland',
    source: 'FeWo-direkt',
    date: 'Winter 2015',
    stars: 5,
  },
];
---

<Layout title="Bewertungen unserer Gäste" description="Lesen Sie echte Bewertungen unserer Gäste aus Google, Booking.com, TripAdvisor, HolidayCheck und FeWo-direkt über den Koflerhof in Südtirol.">

  <div class="relative pt-32 pb-24 md:pt-52 md:pb-32 overflow-hidden bg-stone-900">
    <img src="/images/hof/Familie Griesser 2.jpg" alt="Familie Griesser" class="absolute inset-0 w-full h-full object-cover opacity-30 object-top" />
    <div class="relative container mx-auto px-6 md:px-12 text-center text-white">
      <p class="section-subtitle">Was unsere Gäste sagen</p>
      <h1 class="font-serif text-5xl md:text-6xl text-white mb-4">Bewertungen</h1>
      <div class="deco-line"></div>
    </div>
  </div>

  <!-- Rating overview -->
  <section class="py-16 bg-white border-b border-stone-100">
    <div class="container mx-auto px-6 md:px-12">
      <div class="flex flex-wrap justify-center gap-8 md:gap-16 text-center">
        {[
          { platform: 'Google', rating: '5.0', stars: 5, count: '8 Bewertungen' },
          { platform: 'Booking.com', rating: '9.8', stars: 5, count: 'Sehr gut' },
          { platform: 'FeWo-direkt', rating: '5.0', stars: 5, count: '4 Bewertungen' },
          { platform: 'TripAdvisor', rating: '5.0', stars: 5, count: 'Ausgezeichnet' },
        ].map(item => (
          <div class="fade-in">
            <div class="font-serif text-4xl text-forest-700 mb-1">{item.rating}</div>
            <div class="flex justify-center gap-0.5 mb-1">
              {Array.from({ length: item.stars }).map(() => (
                <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
            <div class="text-sm font-medium text-stone-700">{item.platform}</div>
            <div class="text-xs text-stone-400 mt-0.5">{item.count}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Reviews grid -->
  <section class="py-24 md:py-32 bg-linen">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {reviews.map(review => (
          <div class="fade-in">
            <ReviewCard {...review} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Platforms links -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-6 md:px-12 text-center">
      <h2 class="font-serif text-2xl text-stone-800 mb-4">Eigene Bewertung hinterlassen</h2>
      <p class="text-stone-600 mb-8">War Ihr Aufenthalt auf dem Koflerhof unvergesslich? Wir freuen uns über Ihre Bewertung!</p>
      <div class="flex flex-wrap justify-center gap-4">
        {[
          { name: 'Google', href: '#' },
          { name: 'Booking.com', href: '#' },
          { name: 'TripAdvisor', href: '#' },
          { name: 'FeWo-direkt', href: '#' },
        ].map(p => (
          <a href={p.href} target="_blank" rel="noopener" class="btn-outline text-sm py-2 px-6">{p.name} →</a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-forest-700 text-white">
    <div class="container mx-auto px-6 md:px-12 text-center">
      <h2 class="font-serif text-3xl text-white mb-4">Schreiben auch Sie Ihre Geschichte</h2>
      <p class="text-white/80 max-w-xl mx-auto mb-8">Werden Sie Teil unserer Koflerhof-Familie. Anfragen Sie noch heute Ihren Urlaub.</p>
      <a href="/anfrage" class="btn-gold">Jetzt anfragen</a>
    </div>
  </section>

</Layout>
