---
interface Props {
  images: { src: string; alt: string }[];
  columns?: number;
}

const { images, columns = 4 } = Astro.props;

const gridCols = {
  2: 'grid-cols-2',
  3: 'grid-cols-2 md:grid-cols-3',
  4: 'grid-cols-2 md:grid-cols-3 lg:grid-cols-4',
}[columns] ?? 'grid-cols-2 md:grid-cols-3 lg:grid-cols-4';

const imagesList = JSON.stringify(images.map(i => i.src));
---

<div class={`grid ${gridCols} gap-2`}>
  {images.map((img, idx) => (
    <button
      class="aspect-[4/3] overflow-hidden group cursor-zoom-in"
      onclick={`openLightbox(${imagesList}, ${idx})`}
    >
      <img
        src={img.src}
        alt={img.alt}
        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
        loading="lazy"
      />
    </button>
  ))}
</div>
