---
interface Props {
  text: string;
  author: string;
  source: string;
  date: string;
  stars?: number;
  headline?: string;
}

const { text, author, source, date, stars = 5, headline } = Astro.props;
---

<div class="bg-white p-8 shadow-sm hover:shadow-md transition-shadow duration-300 relative">
  <!-- Quote mark -->
  <div class="text-6xl font-serif text-gold/20 leading-none absolute top-4 left-6 select-none">"</div>

  <!-- Stars -->
  <div class="flex gap-0.5 mb-4">
    {Array.from({ length: stars }).map(() => (
      <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
      </svg>
    ))}
  </div>

  {headline && (
    <h4 class="font-serif text-lg text-stone-800 mb-3 leading-snug">{headline}</h4>
  )}

  <p class="text-stone-600 text-sm leading-relaxed italic mb-6">{text}</p>

  <div class="flex items-center justify-between border-t border-stone-100 pt-4">
    <div>
      <span class="text-sm font-medium text-stone-700">{author}</span>
      <span class="text-xs text-stone-400 ml-2">{date}</span>
    </div>
    <span class="text-xs tracking-widest uppercase text-gold bg-gold/10 px-2 py-1">{source}</span>
  </div>
</div>
