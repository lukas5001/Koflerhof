---
const navItems = [
  {
    label: 'Ferienwohnungen',
    href: '/ferienwohnungen',
    dropdown: [
      { label: 'Wohnung Ost', href: '/ferienwohnungen/ost' },
      { label: 'Wohnung West', href: '/ferienwohnungen/west' },
      { label: 'Wohnung West 2', href: '/ferienwohnungen/west2' },
      { label: 'Wohnung Südost', href: '/ferienwohnungen/suedost' },
      { label: 'Wohnung Südwest', href: '/ferienwohnungen/suedwest' },
    ],
  },
  { label: 'Hofleben', href: '/hofleben' },
  {
    label: 'Südtirol erleben',
    href: '/jahreszeiten',
    dropdown: [
      { label: 'Frühling', href: '/jahreszeiten/fruehling' },
      { label: 'Sommer', href: '/jahreszeiten/sommer' },
      { label: 'Herbst', href: '/jahreszeiten/herbst' },
      { label: 'Winter', href: '/jahreszeiten/winter' },
    ],
  },
  { label: 'Angebote', href: '/angebote' },
  { label: 'Preise', href: '/preise' },
  { label: 'Lage', href: '/lage' },
  { label: 'Bewertungen', href: '/bewertungen' },
];

const currentPath = Astro.url.pathname;
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
  <!-- Top bar -->
  <div id="top-bar" class="hidden md:flex items-center justify-between px-8 py-2 text-xs tracking-widest transition-all duration-500">
    <div class="flex items-center gap-6 text-white/80">
      <a href="tel:+390471706038" class="hover:text-gold transition-colors flex items-center gap-1">
        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
        +39 0471 706 038
      </a>
      <a href="tel:+393404191634" class="hover:text-gold transition-colors flex items-center gap-1">
        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
        +39 340 4191634
      </a>
      <a href="mailto:info@koflerhof.bz" class="hover:text-gold transition-colors flex items-center gap-1">
        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/><path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/></svg>
        info@koflerhof.bz
      </a>
    </div>
    <div class="flex items-center gap-3 text-white/70">
      <span>DE</span>
      <span class="text-white/30">|</span>
      <a href="#" class="hover:text-gold transition-colors">IT</a>
      <span class="text-white/30">|</span>
      <a href="#" class="hover:text-gold transition-colors">EN</a>
    </div>
  </div>

  <!-- Main nav -->
  <nav id="main-nav" class="flex items-center justify-between px-6 md:px-12 py-4 transition-all duration-500">
    <!-- Logo -->
    <a href="/" class="flex flex-col items-start group">
      <span class="font-serif text-2xl md:text-3xl text-white group-hover:text-gold transition-colors leading-none tracking-wide">Koflerhof</span>
      <span class="font-sans text-[9px] tracking-[0.35em] uppercase text-white/70 group-hover:text-gold/70 transition-colors mt-0.5">Ferienwohnungen · Südtirol</span>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden lg:flex items-center gap-1">
      {navItems.map(item => (
        <li class="relative group">
          {item.dropdown ? (
            <>
              <a
                href={item.href}
                class:list={[
                  'nav-link px-4 py-2 flex items-center gap-1',
                  currentPath.startsWith(item.href) ? 'text-gold' : 'text-white'
                ]}
              >
                {item.label}
                <svg class="w-3 h-3 mt-0.5 transition-transform duration-200 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </a>
              <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                <ul class="bg-white shadow-2xl min-w-[220px] border-t-2 border-gold py-2">
                  {item.dropdown.map(sub => (
                    <li>
                      <a
                        href={sub.href}
                        class:list={[
                          'block px-6 py-2.5 text-sm tracking-wider font-sans text-stone-700 hover:text-forest-700 hover:bg-cream transition-all duration-150',
                          currentPath === sub.href ? 'text-forest-700 font-medium' : ''
                        ]}
                      >
                        {sub.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </>
          ) : (
            <a
              href={item.href}
              class:list={[
                'nav-link px-4 py-2',
                currentPath === item.href ? 'text-gold' : 'text-white'
              ]}
            >
              {item.label}
            </a>
          )}
        </li>
      ))}
    </ul>

    <!-- CTA Button desktop -->
    <a href="/anfrage" class="hidden lg:inline-block btn-gold text-xs py-2.5 px-6">
      Anfrage senden
    </a>

    <!-- Mobile hamburger -->
    <button id="hamburger" class="lg:hidden text-white p-2" aria-label="Menu öffnen">
      <div class="hamburger-line w-6 h-0.5 bg-current mb-1.5 transition-all duration-300"></div>
      <div class="hamburger-line w-6 h-0.5 bg-current mb-1.5 transition-all duration-300"></div>
      <div class="hamburger-line w-4 h-0.5 bg-current transition-all duration-300"></div>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="lg:hidden hidden bg-stone-900/98 backdrop-blur-sm">
    <div class="px-6 py-4 border-t border-white/10">
      {navItems.map(item => (
        <div class="border-b border-white/10 last:border-0">
          {item.dropdown ? (
            <details class="group/detail">
              <summary class="flex items-center justify-between py-4 text-white text-sm tracking-widest uppercase cursor-pointer list-none hover:text-gold transition-colors">
                {item.label}
                <svg class="w-4 h-4 transition-transform duration-200 group-open/detail:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <div class="pb-2 pl-4">
                {item.dropdown.map(sub => (
                  <a href={sub.href} class="block py-2.5 text-white/70 text-sm tracking-wider hover:text-gold transition-colors">{sub.label}</a>
                ))}
              </div>
            </details>
          ) : (
            <a href={item.href} class="block py-4 text-white text-sm tracking-widest uppercase hover:text-gold transition-colors">
              {item.label}
            </a>
          )}
        </div>
      ))}
      <div class="pt-6 pb-4 flex flex-col gap-3">
        <a href="tel:+390471706038" class="text-white/70 text-sm tracking-wider">+39 0471 706 038</a>
        <a href="mailto:info@koflerhof.bz" class="text-white/70 text-sm tracking-wider">info@koflerhof.bz</a>
        <a href="/anfrage" class="btn-gold text-center mt-2">Anfrage senden</a>
      </div>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const topBar = document.getElementById('top-bar');
  const mainNav = document.getElementById('main-nav');
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobile-menu');
  const hamburgerLines = document.querySelectorAll('.hamburger-line');

  let isScrolled = false;

  function updateHeader() {
    isScrolled = window.scrollY > 60;
    if (isScrolled) {
      header?.classList.add('bg-stone-900/95', 'backdrop-blur-md', 'shadow-xl');
      header?.classList.remove('bg-transparent');
      topBar?.classList.add('hidden');
    } else {
      header?.classList.remove('bg-stone-900/95', 'backdrop-blur-md', 'shadow-xl');
      topBar?.classList.remove('hidden');
    }
  }

  window.addEventListener('scroll', updateHeader);
  updateHeader();

  // Mobile menu toggle
  hamburger?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    if (isOpen) {
      mobileMenu?.classList.add('hidden');
      hamburgerLines[2]?.classList.remove('w-6');
    } else {
      mobileMenu?.classList.remove('hidden');
      header?.classList.add('bg-stone-900/95');
      hamburgerLines[2]?.classList.add('w-6');
    }
  });
</script>
