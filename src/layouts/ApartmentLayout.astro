---
import Layout from './Layout.astro';
import Gallery from '../components/Gallery.astro';
import { getLangFromUrl, getLangPrefix } from '../i18n/utils';
import { ui } from '../i18n/ui';

interface Props {
  title: string;
  subtitle: string;
  description: string;
  headerImage: string;
  persons: string;
  floor: string;
  bedrooms: string;
  extra?: string;
  badge?: string;
  beds: string[];
  features: string[];
  inclusions: string[];
  gallery: { src: string; alt: string }[];
  floorPlan?: string;
  prevApt?: { name: string; href: string };
  nextApt?: { name: string; href: string };
}

const {
  title, subtitle, description, headerImage,
  persons, floor, bedrooms, extra, badge,
  beds, features, inclusions, gallery, floorPlan,
  prevApt, nextApt,
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const prefix = getLangPrefix(lang);
const t = ui[lang].apt;
---

<Layout title={title} description={description} image={headerImage}>

  <!-- HEADER -->
  <div class="relative pt-32 pb-24 md:pt-52 md:pb-32 overflow-hidden bg-stone-900">
    <img src={headerImage} alt={title} class="absolute inset-0 w-full h-full object-cover opacity-50" />
    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-black/30"></div>
    <div class="relative container mx-auto px-6 md:px-12 text-white">
      <p class="section-subtitle text-center">{subtitle}</p>
      <h1 class="font-serif text-5xl md:text-6xl text-white text-center mb-4">{title}</h1>
      <div class="deco-line mb-8"></div>
      <div class="flex flex-wrap justify-center gap-8 text-center">
        <div>
          <div class="font-serif text-3xl text-gold">{persons}</div>
          <div class="text-xs tracking-widest uppercase text-white/70 mt-1">{t.persons}</div>
        </div>
        <div class="w-px bg-white/20"></div>
        <div>
          <div class="font-serif text-3xl text-gold">{bedrooms}</div>
          <div class="text-xs tracking-widest uppercase text-white/70 mt-1">{t.bedrooms}</div>
        </div>
        <div class="w-px bg-white/20"></div>
        <div>
          <div class="font-serif text-sm text-gold mt-2">{floor}</div>
          <div class="text-xs tracking-widest uppercase text-white/70 mt-1">{t.location}</div>
        </div>
        {extra && (
          <>
            <div class="w-px bg-white/20"></div>
            <div>
              <div class="font-serif text-sm text-gold mt-2">{extra}</div>
              <div class="text-xs tracking-widest uppercase text-white/70 mt-1">{t.special}</div>
            </div>
          </>
        )}
      </div>
    </div>
  </div>

  <!-- BREADCRUMB -->
  <div class="bg-cream border-b border-stone-200">
    <div class="container mx-auto px-6 md:px-12 py-3 flex items-center gap-2 text-xs tracking-wider text-stone-500">
      <a href={`${prefix}/`} class="hover:text-gold transition-colors">{t.home}</a>
      <span>/</span>
      <a href={`${prefix}/ferienwohnungen`} class="hover:text-gold transition-colors">{t.aptsOverview}</a>
      <span>/</span>
      <span class="text-stone-700">{title}</span>
    </div>
  </div>

  <!-- DESCRIPTION & FEATURES -->
  <section class="py-24 md:py-32 bg-linen">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid lg:grid-cols-3 gap-16">

        <!-- Main content -->
        <div class="lg:col-span-2 fade-in">
          {badge && (
            <div class="inline-block bg-forest-700 text-white text-xs tracking-widest uppercase px-4 py-2 mb-6">
              {badge}
            </div>
          )}
          <p class="prose-kofler mb-10" set:html={description}></p>

          <!-- Beds -->
          <div class="mb-10">
            <h3 class="font-serif text-2xl text-stone-800 mb-4">{t.sleepingOptions}</h3>
            <div class="grid sm:grid-cols-2 gap-3">
              {beds.map(bed => (
                <div class="flex items-center gap-3 bg-white p-3 shadow-sm">
                  <svg class="w-5 h-5 text-gold shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                  </svg>
                  <span class="text-sm text-stone-700">{bed}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Features -->
          <div>
            <h3 class="font-serif text-2xl text-stone-800 mb-4">{t.equipment}</h3>
            <div class="grid sm:grid-cols-2 gap-3">
              {features.map(feat => (
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-gold shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                  <span class="text-sm text-stone-700">{feat}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="fade-in space-y-6">
          <!-- Included -->
          <div class="bg-white p-8 shadow-sm">
            <h3 class="font-serif text-xl text-stone-800 mb-4">{t.included}</h3>
            <ul class="space-y-2.5">
              {inclusions.map(item => (
                <li class="flex items-start gap-2.5">
                  <svg class="w-4 h-4 text-forest-700 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                  <span class="text-sm text-stone-600">{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Shared facilities -->
          <div class="bg-forest-700 text-white p-8">
            <h3 class="font-serif text-xl text-white mb-4">{t.sharedTitle}</h3>
            <ul class="space-y-2.5">
              {t.sharedInclusions.map(item => (
                <li class="flex items-start gap-2.5">
                  <svg class="w-4 h-4 text-gold shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                  <span class="text-sm text-white/80">{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- CTA -->
          <div class="bg-cream p-8 shadow-sm text-center">
            <p class="font-serif text-lg text-stone-800 mb-2">{t.ctaTitle}</p>
            <p class="text-sm text-stone-600 mb-6">{t.ctaText}</p>
            <a href={`${prefix}/anfrage`} class="btn-primary w-full text-center block">{t.inquireBtn}</a>
            <a href={`${prefix}/preise`} class="block mt-3 text-sm text-stone-500 hover:text-forest-700 transition-colors">{t.pricesLink}</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- GALLERY -->
  {gallery.length > 0 && (
    <section class="py-24 md:py-32 bg-white">
      <div class="container mx-auto px-6 md:px-12">
        <div class="text-center mb-12 fade-in">
          <p class="section-subtitle">{t.gallery}</p>
          <h2 class="section-title">{t.galleryTitle}</h2>
          <div class="deco-line"></div>
        </div>
        <div class="fade-in">
          <Gallery images={gallery} columns={4} />
        </div>
      </div>
    </section>
  )}

  <!-- FLOOR PLAN -->
  {floorPlan && (
    <section class="py-16 bg-cream">
      <div class="container mx-auto px-6 md:px-12">
        <div class="text-center mb-8 fade-in">
          <h3 class="font-serif text-2xl text-stone-800">{t.floorPlan}</h3>
        </div>
        <div class="max-w-2xl mx-auto fade-in">
          <img src={floorPlan} alt={`${t.floorPlan} ${title}`} class="w-full object-contain" />
        </div>
      </div>
    </section>
  )}

  <!-- NAVIGATION between apartments -->
  <section class="py-12 bg-stone-900 text-white">
    <div class="container mx-auto px-6 md:px-12">
      <div class="flex items-center justify-between">
        {prevApt ? (
          <a href={prevApt.href} class="flex items-center gap-3 group">
            <svg class="w-5 h-5 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
            <div>
              <div class="text-xs tracking-widest uppercase text-stone-500">{t.prevApt}</div>
              <div class="font-serif text-lg text-white group-hover:text-gold transition-colors">{prevApt.name}</div>
            </div>
          </a>
        ) : <div></div>}

        <a href={`${prefix}/ferienwohnungen`} class="text-xs tracking-widest uppercase text-gold hover:text-yellow-400 transition-colors">
          {t.allApts}
        </a>

        {nextApt ? (
          <a href={nextApt.href} class="flex items-center gap-3 group text-right">
            <div>
              <div class="text-xs tracking-widest uppercase text-stone-500">{t.nextApt}</div>
              <div class="font-serif text-lg text-white group-hover:text-gold transition-colors">{nextApt.name}</div>
            </div>
            <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        ) : <div></div>}
      </div>
    </div>
  </section>

</Layout>
