---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl } from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = 'Ferienwohnungen am Bauernhof in Südtirol – Koflerhof bei Kastelruth in der Nähe der Seiser Alm. Familienfreundlich, authentisch, herzlich.',
  image = '/images/hof/Koflerhof Hausansicht Sommer 1.JPG',
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <title>{title} | Koflerhof Südtirol</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
  </head>
  <body class="overflow-x-hidden">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

    <div id="lightbox" class="lightbox-overlay" onclick="closeLightbox()">
      <button onclick="lightboxNav(-1)" class="absolute left-4 text-white text-4xl hover:text-gold transition-colors z-10 bg-black/30 w-12 h-12 flex items-center justify-center">&#8249;</button>
      <img id="lightbox-img" src="" alt="" class="max-w-[90vw] max-h-[90vh] object-contain" onclick="event.stopPropagation()" />
      <button onclick="lightboxNav(1)" class="absolute right-4 text-white text-4xl hover:text-gold transition-colors z-10 bg-black/30 w-12 h-12 flex items-center justify-center">&#8250;</button>
      <button onclick="closeLightbox()" class="absolute top-4 right-4 text-white text-2xl hover:text-gold transition-colors bg-black/30 w-10 h-10 flex items-center justify-center">&#x2715;</button>
    </div>

    <script>
      let lightboxImages: string[] = [];
      let lightboxIndex = 0;

      function openLightbox(images: string[], index: number) {
        lightboxImages = images;
        lightboxIndex = index;
        const lb = document.getElementById('lightbox');
        const img = document.getElementById('lightbox-img') as HTMLImageElement;
        if (lb && img) {
          img.src = images[index];
          lb.classList.add('active');
          document.body.style.overflow = 'hidden';
        }
      }

      function closeLightbox() {
        const lb = document.getElementById('lightbox');
        if (lb) {
          lb.classList.remove('active');
          document.body.style.overflow = '';
        }
      }

      function lightboxNav(dir: number) {
        lightboxIndex = (lightboxIndex + dir + lightboxImages.length) % lightboxImages.length;
        const img = document.getElementById('lightbox-img') as HTMLImageElement;
        if (img) img.src = lightboxImages[lightboxIndex];
      }

      document.addEventListener('keydown', (e) => {
        if (document.getElementById('lightbox')?.classList.contains('active')) {
          if (e.key === 'Escape') closeLightbox();
          if (e.key === 'ArrowRight') lightboxNav(1);
          if (e.key === 'ArrowLeft') lightboxNav(-1);
        }
      });

      (window as any).openLightbox = openLightbox;
      (window as any).closeLightbox = closeLightbox;
      (window as any).lightboxNav = lightboxNav;

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      }, { threshold: 0.1 });

      document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
    </script>
  </body>
</html>
